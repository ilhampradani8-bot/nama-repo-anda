---
// Sidebar.astro - Navigation Sidebar for Legal & Info pages
interface Props {
	activePage: string;
}

const { activePage } = Astro.props;

const links = [
	{ name: 'about', emoji: 'ℹ️', title: 'Tentang Kami', url: '/about' },
	{ name: 'term', emoji: '📄', title: 'Syarat & Ketentuan', url: '/term' },
	{ name: 'condition', emoji: '🤝', title: 'Kebijakan Refund', url: '/condition' },
	{ name: 'security', emoji: '🛡️', title: 'Keamanan & Privasi', url: '/security' },
	{ name: 'legalitas', emoji: '⚖️', title: 'Legalitas Resmi', url: '/legalitas' },
];
---
<aside class="docs-sidebar" style="width: 280px; flex-shrink: 0; border-right: 1px solid var(--border-color); background: #fafafa; padding: 2rem 1.5rem; position: sticky; top: 68px; height: calc(100vh - 68px); overflow-y: auto; z-index: 10;">
    <h3 style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 1.2rem; font-weight: 700; padding-left: 0.5rem;">Informasi & Legalitas</h3>
    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem;">
        {links.map((link) => (
            <li>
                <a 
                    href={link.url} 
                    class={`docs-nav-link ${activePage === link.name ? 'active' : ''}`}
                    style="display: flex; align-items: center; gap: 0.75rem; padding: 0.7rem 1rem; border-radius: var(--radius); color: var(--text-main); text-decoration: none; font-weight: 500; font-size: 0.9rem; transition: all 0.15s;"
                >
                    <span style="font-size: 1.1rem; line-height: 1;">{link.emoji}</span> {link.title}
                </a>
            </li>
        ))}
    </ul>
</aside>
