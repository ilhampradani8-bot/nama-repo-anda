            <div class="contact-details">
                <p><strong>WhatsApp:</strong> <a href="https://wa.me/6288971071138" target="_blank">+62 889-7107-1138</a></p>
                <p><strong>Email 1:</strong> <a href="mailto:hello@ilhampradani.me">hello@ilhampradani.me</a></p>
                <p><strong>Email 2:</strong> <a href="mailto:easymall@ilhampradani.me">easymall@ilhampradani.me</a></p>
