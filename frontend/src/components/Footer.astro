---
// Footer.astro - Shared Footer Component
---
<div class="footer-top-brand-banner" style="width: 100%; background: var(--primary); color: #ffffff; display: flex; align-items: center; justify-content: center; padding: 0.8rem 0; font-weight: 800; letter-spacing: 0.6em; font-size: 1.5rem; text-transform: uppercase; line-height: 1; margin-top: 4rem; border-bottom: 1px solid var(--border-color);">
    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.95); margin: 0 12px; flex-shrink: 0;"><path d="M12 2 L15 12 L12 22 L9 12 Z" /><path d="M12 6 C6 3 3 8 9 12 C15 16 18 21 12 22" /><path d="M12 6 C18 3 21 8 15 12 C9 16 6 21 12 22" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg>
    EASYMALL
    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="color: rgba(255,255,255,0.95); margin: 0 12px; flex-shrink: 0;"><path d="M12 2 L15 12 L12 22 L9 12 Z" /><path d="M12 6 C6 3 3 8 9 12 C15 16 18 21 12 22" /><path d="M12 6 C18 3 21 8 15 12 C9 16 6 21 12 22" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg>
</div>
<footer class="site-footer" style="margin-top: 0; padding-top: 3rem;">
    <div class="footer-container">
        <!-- Left Column: Logo only -->
        <div class="footer-col footer-info" style="display: flex; align-items: center; justify-content: flex-start;">
            <img src="/gambar/logoeasyfast.webp" alt="EasyMall Logo" class="footer-logo" style="margin-bottom: 0; height: 200px; width: auto; object-fit: contain;">
        </div>

        <!-- Column 2: Kategori & Lainnya -->
        <div class="footer-col footer-links">
            <h4>Kategori</h4>
            <ul style="margin-bottom: 2rem;">
                <li><a href="/#products" onclick="footerFilterCategory('all')">Semua Produk</a></li>
                <li><a href="/#products" onclick="footerFilterCategory('Koala Store')">Top Up Game</a></li>
                <li><a href="/#products" onclick="footerFilterCategory('Portal Pulsa')">Pulsa & Paket Data</a></li>
                <li><a href="/#products" onclick="footerFilterCategory('SSL Store')">SSL Certificate</a></li>
            </ul>

            <h4>Lainnya</h4>
            <ul>
                <li style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.8rem; font-weight: 500;">CEO Web</li>
                <li style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.8rem; font-weight: 500;">Academy</li>
                <li style="color: var(--text-muted); font-size: 0.9rem; font-weight: 500;">Easymall</li>
            </ul>
        </div>

        <!-- Column 3: Informasi -->
        <div class="footer-col footer-links">
            <h4>Informasi</h4>
            <ul>
                <li><a href="/about">Tentang Kami</a></li>
                <li><a href="/term">Syarat & Ketentuan</a></li>
                <li><a href="/condition">Kebijakan Refund</a></li>
                <li><a href="/security">Keamanan & Privasi</a></li>
                <li><a href="/legalitas">Legalitas Resmi</a></li>
            </ul>
        </div>

        <!-- Column 4: Kontak & Search -->
        <div class="footer-col footer-contact">
            <h4>Kontak</h4>
            <div class="contact-details" style="display: flex; flex-direction: column; gap: 0.75rem;">
                <div style="display: flex; align-items: center; gap: 8px;">
