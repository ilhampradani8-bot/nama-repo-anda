                    <a href="https://wa.me/6288971071138" target="_blank" style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none;">+62 889-7107-1138</a>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="color: #0d6efd; flex-shrink: 0;"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/></svg>
                    <a href="mailto:hello@ilhampradani.me" style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none;">hello@ilhampradani.me</a>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" style="color: #0d6efd; flex-shrink: 0;"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/></svg>
                    <a href="mailto:easymall@ilhampradani.me" style="color: var(--text-muted); font-size: 0.85rem; text-decoration: none;">easymall@ilhampradani.me</a>
                </div>
                <h4 style="margin-top: 1.5rem;">Cari Produk</h4>
                <div class="footer-search">
                    <input type="text" placeholder="Ketik nama produk..." id="footerSearchInput" class="footer-search-input">
                    <button type="button" id="footerSearchBtn" class="footer-search-btn">Cari</button>
                </div>
            </div>
        </div>
    </div>
    
    <div class="footer-bottom" style="margin-top: 2rem;">
        <!-- Payment Methods Section Row -->
        <div class="payment-methods-row" style="display: flex; justify-content: center; align-items: center; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap;">
            <div style="display: flex; gap: 1.25rem; flex-wrap: wrap; justify-content: center; align-items: center;">
                <img src="/gambar/gambar_footer/Qris-logo.webp" alt="QRIS" style="height: 24px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/bca.webp" alt="BCA" style="height: 18px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/mandiri.webp" alt="Mandiri" style="height: 14px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/bni.webp" alt="BNI" style="height: 15px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/bri.webp" alt="BRI" style="height: 18px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/gopay.webp" alt="Gopay" style="height: 15px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/dana.webp" alt="DANA" style="height: 15px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
                <img src="/gambar/gambar_footer/ovo.webp" alt="OVO" style="height: 15px; width: auto; object-fit: contain; filter: grayscale(100%); opacity: 0.7; transition: all 0.2s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(100%)'; this.style.opacity='0.7'">
