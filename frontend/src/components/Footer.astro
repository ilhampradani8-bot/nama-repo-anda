            </ul>
        </div>

        <!-- Middle Column 2: Legal & Info -->
        <div class="footer-col footer-links">
            <h4>Informasi & Legalitas</h4>
            <ul>
                <li><a href="/about">ℹ️ Tentang Kami</a></li>
                <li><a href="/term">📄 Syarat & Ketentuan</a></li>
                <li><a href="/condition">🤝 Kebijakan Refund</a></li>
