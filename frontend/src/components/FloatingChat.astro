---
// FloatingChat.astro - Floating Capsule Chat Widget
---
<div class="floating-chat-widget">
    <!-- Chat Toggle Capsule -->
    <button type="button" id="btnFloatingChatToggle" class="chat-capsule-toggle" aria-label="Buka Chat Layanan">
