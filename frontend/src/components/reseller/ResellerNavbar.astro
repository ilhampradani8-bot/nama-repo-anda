---
// ResellerNavbar.astro
import ResellerProfileCard from './ResellerProfileCard.astro';
---
<div id="top-loading-bar" class="loading-bar"></div>

<nav class="navbar">
    <a href="/" class="navbar-brand">
        <img src="/gambar/logo/easymall-logo.png" alt="EasyMall Logo">
        <span>EasyMall</span>
    </a>
    <div class="nav-actions">
        <a href="/" class="btn-link" title="Belanja">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="9" cy="21" r="1"></circle>
                <circle cx="20" cy="21" r="1"></circle>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
            </svg>
        </a>
        <a href="/mymall.html" class="btn-mymall" title="Kunjungi My Mall Anda">
            <svg class="castle-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 19V8H18V5H15V8H9V5H6V8H3V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19Z"></path>
                <path d="M12 21V16H10V21"></path>
                <path d="M12 12V8"></path>
                <path d="M14 10H10"></path>
            </svg>
            <span class="mymall-prefix">My</span>
            <span class="mymall-scroller">
                <span class="mymall-words">
                    <span>Mall</span>
                    <span>Stand</span>
                    <span>Store</span>
                    <span>Product</span>
                    <span>Prestise</span>
                    <span>Museum</span>
                </span>
            </span>
        </a>
        <div class="profile-dropdown-container">
            <button class="btn-profile-toggle" id="btnProfileToggle" aria-label="Toggle Menu Profil">
                <img src="/grabill54-hello-2488_512.gif" alt="Profile Avatar" class="profile-gif-avatar">
            </button>
            <div class="profile-dropdown-menu" id="profileDropdownMenu">
                <ResellerProfileCard />
                <div class="dropdown-footer">
                    <button class="btn-dropdown-logout" onclick="performLogout()">🚪 Keluar</button>
                </div>
            </div>
        </div>
    </div>
</nav>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Marcellus+SC&display=swap');

    .loading-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        background: #0d6efd;
        width: 0%;
        transition: width 0.3s ease, opacity 0.3s ease;
        z-index: 1001;
        opacity: 0;
        pointer-events: none;
    }
    .loading-bar.active {
        opacity: 1;
        width: 70%;
    }
    .loading-bar.finish {
        opacity: 0;
        width: 100%;
        transition: width 0.2s ease, opacity 0.2s ease;
    }

    .navbar {
        background: #e2ffff;
        border-bottom: 2px solid #dee2e6;
        padding: 0 1.5rem;
        height: 70px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        z-index: 100;
    }

    .navbar-brand {
        font-weight: bold;
        font-size: 1.25rem;
        color: #212529;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .navbar-brand img {
        height: 32px;
    }

    .nav-actions {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        height: 100%;
    }

    .btn-link {
        color: #495057;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        transition: color 0.15s ease, transform 0.15s ease;
    }

    .btn-link:hover {
        color: #0d6efd;
        text-decoration: none;
        transform: scale(1.1);
    }


    /* My Mall Button & Scroller styling */
    .btn-mymall {
        display: flex;
        align-items: center;
        gap: 6px;
        background: linear-gradient(135deg, #6610f2 0%, #0d6efd 100%);
        color: #ffffff !important;
        text-decoration: none !important;
        font-weight: 600;
        font-size: 0.85rem;
        font-family: 'Marcellus SC', serif;
        padding: 6px 12px;
        border-radius: 50px;
        box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);
        transition: all 0.2s ease;
        height: 38px;
        overflow: hidden;
    }

    .btn-mymall:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(13, 110, 253, 0.3);
    }

    .btn-mymall .castle-icon {
        color: #fff;
    }

    .mymall-prefix {
        font-weight: 500;
        color: rgba(255, 255, 255, 0.9);
        font-family: 'Marcellus SC', serif;
    }

    .mymall-scroller {
        height: 20px;
        overflow: hidden;
        position: relative;
        display: inline-block;
        width: 60px; /* ensure enough width for the longest word */
    }

    .mymall-words {
        display: flex;
        flex-direction: column;
        position: absolute;
        top: 0;
        left: 0;
        animation: scrollWords 12s infinite cubic-bezier(0.645, 0.045, 0.355, 1);
    }

    .mymall-words span {
        display: block;
        height: 20px;
        line-height: 20px;
        color: #ffffff;
        font-weight: 700;
        font-family: 'Marcellus SC', serif;
        text-shadow: 0 1px 2px rgba(0,0,0,0.1);
        text-align: left;
    }

    @keyframes scrollWords {
        0%, 12% {
            transform: translateY(0);
        }
        16.6%, 28.6% {
            transform: translateY(-20px);
        }
        33.3%, 45.3% {
            transform: translateY(-40px);
        }
        50%, 62% {
            transform: translateY(-60px);
        }
        66.6%, 78.6% {
            transform: translateY(-80px);
        }
        83.3%, 95% {
            transform: translateY(-100px);
        }
        100% {
            transform: translateY(0);
        }
    }

    .profile-dropdown-container {
        position: relative;
        display: inline-block;
        height: 100%;
    }
    
    .btn-profile-toggle {
        background: transparent;
        border: none;
        padding: 0;
        cursor: pointer;
        outline: none;
        width: 70px;
        height: 100%;
        transition: transform 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .btn-profile-toggle:hover {
        transform: scale(1.05);
    }
    
    .profile-gif-avatar {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .profile-dropdown-menu {
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        width: 260px;
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 6px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        display: none;
        flex-direction: column;
        z-index: 1000;
        overflow: hidden;
        animation: dropdown-fade-in 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .profile-dropdown-menu.active {
        display: flex;
    }
    
    @keyframes dropdown-fade-in {
        from {
            opacity: 0;
            transform: translateY(8px) scale(0.95);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }
    
    .profile-dropdown-menu :global(.profile-card) {
        border: none !important;
        box-shadow: none !important;
        padding: 1.25rem !important;
        background: #ffffff !important;
    }
    
    .dropdown-footer {
        padding: 0.75rem 1rem;
        background: #f8f9fa;
        border-top: 1px solid #dee2e6;
        display: flex;
        justify-content: center;
    }
    
    .btn-dropdown-logout {
        width: 100%;
        padding: 8px 12px;
        background: #dc3545;
        color: #ffffff;
        border: 1px solid #dc3545;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.85rem;
        cursor: pointer;
        text-align: center;
        transition: background 0.2s;
    }
    
    .btn-dropdown-logout:hover {
        background: #bb2d3b;
        border-color: #b02a37;
    }
</style>

<script is:inline>
    (function() {
        // 1. Loading Bar logic
        const bar = document.getElementById('top-loading-bar');
        if (bar) {
            let activeRequests = 0;
            function startLoading() {
                activeRequests++;
                if (activeRequests === 1) {
                    bar.classList.remove('finish');
                    bar.classList.add('active');
                }
            }
            function stopLoading() {
                activeRequests = Math.max(0, activeRequests - 1);
                if (activeRequests === 0) {
                    bar.classList.remove('active');
                    bar.classList.add('finish');
                    setTimeout(() => {
                        if (activeRequests === 0) {
                            bar.classList.remove('finish');
                        }
                    }, 300);
                }
            }
            window.startLoadingBar = startLoading;
            window.stopLoadingBar = stopLoading;
            const originalFetch = window.fetch;
            window.fetch = async function(...args) {
                startLoading();
                try {
                    return await originalFetch(...args);
                } finally {
                    stopLoading();
                }
            };
        }

        // 2. Global Perform Logout function
        window.performLogout = async function() {
            try {
                let API_BASE_URL = '';
                if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
                    API_BASE_URL = 'https://api.ilhampradani.me';
                }
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        };

        // 3. Dropdown Menu Toggle logic
        function initProfileDropdown() {
            const toggle = document.getElementById('btnProfileToggle');
            const menu = document.getElementById('profileDropdownMenu');
            if (!toggle || !menu) return;
            
            toggle.addEventListener('click', (e) => {
                e.stopPropagation();
                menu.classList.toggle('active');
            });
            
            document.addEventListener('click', (e) => {
                if (!menu.contains(e.target) && e.target !== toggle) {
                    menu.classList.remove('active');
                }
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initProfileDropdown);
        } else {
            initProfileDropdown();
        }
        document.addEventListener('astro:page-load', initProfileDropdown);
    })();
</script>
