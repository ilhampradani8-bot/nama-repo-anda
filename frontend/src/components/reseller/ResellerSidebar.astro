---
// ResellerSidebar.astro
const { activeTab } = Astro.props;
---

<div class="sidebar-menu">
    <a href="/dashboard_reseller.html" class={`sidebar-btn ${activeTab === 'stats' ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>
        Overview & Stat
    </a>
    <a href="/reseller_koneksi.html" class={`sidebar-btn ${activeTab === 'koneksi' ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect><line x1="1" y1="10" x2="23" y2="10"></line></svg>
        Koneksi API
    </a>
    <a href="/reseller_laporan.html" class={`sidebar-btn ${activeTab === 'laporan' ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        Laporan Penjualan
    </a>
    <a href="/reseller_penjualan.html" class={`sidebar-btn ${activeTab === 'penjualan' ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
        Data Penjualan
    </a>
    <a href="/reseller_keuntungan.html" class={`sidebar-btn ${activeTab === 'keuntungan' ? 'active' : ''}`}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
        Keuntungan
    </a>
    <hr class="sidebar-divider" />
    <a href="/dashboard_user.html" class="sidebar-btn user-switch-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        Ke Dashboard User
    </a>
    <button class="sidebar-btn logout-btn" onclick="performLogout()">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sidebar-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"></path></svg>
        Keluar
    </button>
</div>

<style>
    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: 6px;
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 0.75rem;
    }

    .sidebar-btn {
        background: transparent;
        border: none;
        padding: 10px 12px;
        color: #495057;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: left;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.1s ease;
    }

    .sidebar-btn:hover {
        background: #f1f3f5;
        color: #212529;
    }

    .sidebar-btn.active {
        background: #0d6efd;
        color: #ffffff;
    }

    .sidebar-divider {
        border: 0;
        border-top: 1px solid #dee2e6;
        margin: 0.5rem 0;
    }

    .user-switch-btn {
        color: #0d6efd;
    }

    .user-switch-btn:hover {
        background: #e7f1ff;
    }

    .logout-btn {
        color: #dc3545;
        width: 100%;
    }

    .logout-btn:hover {
        background: #fdf2f2;
    }
</style>
