---
// SearchCard.astro
---
<div class="search-card">
    <h3>🔍 Cari Transaksi Anda</h3>
    <div class="search-box">
        <input type="text" id="searchWa" class="search-input" placeholder="Masukkan nomor WhatsApp Anda (contoh: 628123...)">
        <button class="btn-search" onclick="filterTransactions()">Cari</button>
    </div>
</div>

<style>
    .search-card {
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 1.25rem 1.5rem;
    }

    .search-card h3 {
        font-size: 1rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.75rem;
    }

    .search-box {
        display: flex;
        gap: 0.75rem;
    }

    .search-input {
        flex: 1;
        padding: 8px 12px;
        background: #ffffff;
        border: 1px solid #ced4da;
        border-radius: 4px;
        color: #212529;
        font-size: 0.9rem;
        outline: none;
    }

    .search-input:focus {
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    .btn-search {
        padding: 8px 16px;
        background: #007bff;
        color: #ffffff;
        border: 1px solid #007bff;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
    }

    .btn-search:hover {
        background: #0069d9;
        border-color: #0062cc;
    }
</style>
