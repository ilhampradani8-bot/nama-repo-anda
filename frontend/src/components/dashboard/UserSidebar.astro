---
// UserSidebar.astro
const { activeTab } = Astro.props;
---
<div class="sidebar-menu">
    <a href="/dashboard_user.html" class={`sidebar-btn ${activeTab === 'dashboard' ? 'active' : ''}`}>🏠 Dashboard User</a>
    <a href="/dashboard_pesanan.html" class={`sidebar-btn ${activeTab === 'pesanan' ? 'active' : ''}`}>📦 Pesanan Saya</a>
    <a href="/dashboard_produk.html" class={`sidebar-btn ${activeTab === 'produk' ? 'active' : ''}`}>🔑 Produk Saya</a>
    <a href="/dashboard_pengaturan.html" class={`sidebar-btn ${activeTab === 'pengaturan' ? 'active' : ''}`}>⚙️ Pengaturan</a>
    <a href="/dashboard_keranjang.html" class={`sidebar-btn ${activeTab === 'keranjang' ? 'active' : ''}`}>🛒 Keranjang Saya</a>
    <hr class="sidebar-divider" />
    <a href="/dashboard_reseller.html" class="sidebar-btn reseller-switch-btn">🔄 Ke Reseller Dashboard</a>
    <button class="sidebar-btn logout-btn" onclick="performLogout()">🚪 Keluar</button>
</div>

<style>
    .sidebar-menu {
        display: flex;
        flex-direction: column;
        gap: 6px;
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 0.75rem;
    }

    .sidebar-btn {
        background: transparent;
        border: none;
        padding: 10px 12px;
        color: #495057;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        text-align: left;
        cursor: pointer;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.1s ease;
    }

    .sidebar-btn:hover {
        background: #f1f3f5;
        color: #212529;
    }

    .sidebar-btn.active {
        background: #0d6efd;
        color: #ffffff;
    }

    .sidebar-divider {
        border: 0;
        border-top: 1px solid #dee2e6;
        margin: 0.5rem 0;
    }

    .reseller-switch-btn {
        color: #0d6efd;
    }

    .reseller-switch-btn:hover {
        background: #e7f1ff;
    }

    .logout-btn {
        color: #dc3545;
        width: 100%;
    }

    .logout-btn:hover {
        background: #fdf2f2;
    }
</style>
