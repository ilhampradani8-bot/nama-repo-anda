---
// UserProfileCard.astro
---
<div class="profile-card">
    <div class="profile-avatar" id="avatar-initial">-</div>
    <h3 class="profile-name">
        <span id="user-name">Memuat...</span>
        <span id="verified-badge" class="verified-badge" style="display: none;" title="Akun Terverifikasi">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#0d6efd" viewBox="0 0 16 16" style="display: inline-block; vertical-align: middle; margin-left: 4px;">
                <path d="M10.067.87a2.89 2.89 0 0 0-4.134 0l-.622.638-.89-.011a2.89 2.89 0 0 0-2.924 2.924l.01.89-.636.622a2.89 2.89 0 0 0 0 4.134l.637.622-.011.89a2.89 2.89 0 0 0 2.924 2.924l.89-.01.622.636a2.89 2.89 0 0 0 4.134 0l.622-.637.89.011a2.89 2.89 0 0 0 2.924-2.924l-.01-.89.636-.622a2.89 2.89 0 0 0 0-4.134l-.637-.622.011-.89a2.89 2.89 0 0 0-2.924-2.924l-.89.01zm.287 5.984-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7 8.793l2.646-2.647a.5.5 0 0 1 .708.708z"/>
            </svg>
        </span>
    </h3>
    <p class="profile-email" id="user-email">...</p>
    <span class="badge-role">Pelanggan</span>
</div>

<script is:inline>
    (async function() {
        try {
            let API_BASE_URL = '';
            if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
                API_BASE_URL = 'https://api.ilhampradani.me';
            }
            const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
            if (authRes.ok) {
                const authData = await authRes.json();
                if (authData.logged_in) {
                    const nameEl = document.getElementById('user-name');
                    const emailEl = document.getElementById('user-email');
                    const avatarEl = document.getElementById('avatar-initial');
                    const verifiedEl = document.getElementById('verified-badge');
                    
                    if (nameEl) nameEl.textContent = authData.name;
                    if (emailEl) emailEl.textContent = authData.email;
                    if (avatarEl) avatarEl.textContent = authData.name.charAt(0).toUpperCase();
                    if (verifiedEl && authData.verified === 1) {
                        verifiedEl.style.display = 'inline-block';
                    }
                }
            }
        } catch(e) {
            console.error("Error auto-populating UserProfileCard:", e);
        }
    })();
</script>

<style>
    .profile-card {
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 1.5rem;
        text-align: center;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #e9ecef;
        margin: 0 auto 1rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: bold;
        color: #495057;
        border: 2px solid #ced4da;
    }

    .profile-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.25rem;
    }

    .profile-email {
        font-size: 0.85rem;
        color: #6c757d;
        margin-bottom: 1rem;
        word-break: break-all;
    }

    .badge-role {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: #e2e3e5;
        color: #383d41;
        border: 1px solid #d6d8db;
    }
</style>
