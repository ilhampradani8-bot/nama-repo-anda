---
// UserProfileCard.astro
---
<div class="profile-card">
    <div class="profile-avatar" id="avatar-initial">-</div>
    <h3 class="profile-name" id="user-name">Memuat...</h3>
    <p class="profile-email" id="user-email">...</p>
    <span class="badge-role">Pelanggan</span>
</div>

<style>
    .profile-card {
        background: #ffffff;
        border: 2px solid #dee2e6;
        border-radius: 4px;
        padding: 1.5rem;
        text-align: center;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: #e9ecef;
        margin: 0 auto 1rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: bold;
        color: #495057;
        border: 2px solid #ced4da;
    }

    .profile-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0.25rem;
    }

    .profile-email {
        font-size: 0.85rem;
        color: #6c757d;
        margin-bottom: 1rem;
        word-break: break-all;
    }

    .badge-role {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        background: #e2e3e5;
        color: #383d41;
        border: 1px solid #d6d8db;
    }
</style>
