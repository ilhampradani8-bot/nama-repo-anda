---
// dashboard_reseller.astro
import ResellerNavbar from '../components/reseller/ResellerNavbar.astro';
import ResellerProfileCard from '../components/reseller/ResellerProfileCard.astro';
import ResellerSidebar from '../components/reseller/ResellerSidebar.astro';
import ResellerStatsGrid from '../components/reseller/ResellerStatsGrid.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Reseller | EasyMarket Partner</title>
    
    <!-- Favicon & App Icons -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #212529;
            --border-color: #dee2e6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.5;
        }

        /* Container Layout */
        .container {
            max-width: 1140px;
            width: 100%;
            margin: 1.5rem auto;
            padding: 0 1rem;
            flex-grow: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
        }

        .sidebar-col {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .card {
            background: #ffffff;
            border: 2px solid #dee2e6;
            border-radius: 4px;
            overflow: hidden;
        }

        .card-header {
            background: #f8f9fa;
            padding: 0.75rem 1.25rem;
            border-bottom: 2px solid #dee2e6;
            font-weight: bold;
            font-size: 1rem;
            color: #212529;
        }

        /* Classic Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            color: #212529;
        }

        th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid var(--border-color);
        }

        tr:hover td {
            background-color: #f1f3f5;
        }

        code {
            font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.85rem;
            background-color: #e9ecef;
            padding: 2px 4px;
            border-radius: 3px;
            color: #212529;
        }

        .no-data {
            padding: 3rem;
            text-align: center;
            color: #6c757d;
            font-size: 0.95rem;
            background: #ffffff;
        }

        .loading-spinner {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem 1rem;
            color: #0d6efd;
            gap: 10px;
            font-size: 0.9rem;
        }

        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid rgba(13, 110, 253, 0.1);
            border-top-color: #0d6efd;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive Layout */
        @media (max-width: 768px) {
            .container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Reseller Navbar -->
    <ResellerNavbar />

    <!-- Main Container -->
    <div class="container">
        <!-- Sidebar Column -->
        <div class="sidebar-col">
            <ResellerProfileCard />
            <ResellerSidebar activeTab="stats" />
        </div>

        <!-- Main Content Area -->
        <div class="content-area">
            <!-- Stats overview cards -->
            <ResellerStatsGrid />

            <!-- Recent Transactions Table Card -->
            <div class="card">
                <div class="card-header">Transaksi Reseller Terbaru</div>
                <div id="transactions-container" style="overflow-x: auto;">
                    <div class="loading-spinner">
                        <div class="spinner"></div>
                        Memuat data transaksi...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        function formatRupiah(num) {
            if (num === null || num === undefined) return "Rp 0";
            return "Rp " + parseInt(num, 10).toLocaleString('id-ID');
        }

        async function fetchResellerData() {
            try {
                // Fetch profile
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                document.getElementById('reseller-name').textContent = authData.name;
                document.getElementById('reseller-email').textContent = authData.email;
                document.getElementById('avatar-initial').textContent = authData.name.charAt(0).toUpperCase();

                // Fetch transactions and stats
                const dataRes = await fetch(`${API_BASE_URL}/api/dashboard/data`, { credentials: 'include' });
                if (dataRes.ok) {
                    const data = await dataRes.json();
                    if (data.success) {
                        populateStats(data);
                        renderTransactions(data.transactions || []);
                    } else {
                        showError();
                    }
                } else {
                    showError();
                }
            } catch (err) {
                console.error(err);
                showError();
            }
        }

        function populateStats(data) {
            document.getElementById('stat-orders').textContent = data.total_orders;
            document.getElementById('stat-sales').textContent = formatRupiah(data.total_sales);
            document.getElementById('stat-profit').textContent = formatRupiah(data.total_profit);
        }

        function renderTransactions(list) {
            const container = document.getElementById('transactions-container');
            if (list.length === 0) {
                container.innerHTML = '<div class="no-data">Belum ada transaksi reseller tercatat.</div>';
                return;
            }

            container.innerHTML = `
                <table>
                    <thead>
                        <tr>
                            <th>ID Transaksi</th>
                            <th>WhatsApp</th>
                            <th>Produk</th>
                            <th>Varian</th>
                            <th>Total Bayar</th>
                            <th>Tanggal</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${list.map(t => `
                            <tr>
                                <td><code>${t.transaction_id}</code></td>
                                <td>${t.whatsapp_id || '-'}</td>
                                <td>${t.product_name || '-'}</td>
                                <td>${t.variant_name || '-'}</td>
                                <td><span style="color: #28a745; font-weight: bold;">${formatRupiah(t.amount)}</span></td>
                                <td>${t.created_at}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
        }

        function showError() {
            document.getElementById('transactions-container').innerHTML = '<div class="no-data">Gagal memuat data transaksi reseller.</div>';
        }

        async function performLogout() {
            try {
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        }

        fetchResellerData();
    </script>
</body>
</html>
