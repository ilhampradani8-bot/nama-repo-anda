---
// legalitas.astro
import PenggabungPageIncludeFooter from '../layouts/penggabung_pageincludefooter.astro';
---

<PenggabungPageIncludeFooter 
    title="Legalitas Resmi PT Easymall Software Development" 
    description="Informasi legalitas, NIB, Keputusan AHU, dan legalitas operasional PT Easymall Software Development sebagai pengelola resmi EasyMarket."
    activePage="legalitas"
>
    <div class="footer-page-content" style="line-height: 1.8;">
        <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--text-main); border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem;">Legalitas Resmi</h2>
        <p style="font-size: 1.05rem; color: var(--text-muted);">EasyMarket dikelola and dioperasikan secara sah di bawah payung hukum badan usaha resmi di Indonesia:</p>
        
        <div style="background: #fafafa; border: 1px solid var(--border-color); padding: 1.5rem; border-radius: 8px; margin-top: 1.5rem; margin-bottom: 1.5rem;">
            <table style="width: 100%; border-collapse: collapse; font-size: 0.95rem; line-height: 2;">
                <tr>
                    <td style="width: 35%; font-weight: 700; color: var(--text-main); padding: 8px 0;">Nama Perusahaan</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: PT Easymall Software Development</td>
                </tr>
                <tr>
                    <td style="font-weight: 700; color: var(--text-main); padding: 8px 0;">Nomor Induk Berusaha (NIB)</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: 1209230045612</td>
                </tr>
                <tr>
                    <td style="font-weight: 700; color: var(--text-main); padding: 8px 0;">Keputusan AHU</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: AHU-0034561.AH.01.01.Tahun 2026</td>
                </tr>
                <tr>
                    <td style="font-weight: 700; color: var(--text-main); padding: 8px 0;">Sektor Usaha</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: Perdagangan Eceran Piranti Lunak, Penerbitan Piranti Lunak, Portal Web & Platform Digital</td>
                </tr>
                <tr>
                    <td style="font-weight: 700; color: var(--text-main); padding: 8px 0;">Alamat Kantor</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: Jl. Palagan Tentara Pelajar No. 120, Sleman, Yogyakarta</td>
                </tr>
                <tr>
                    <td style="font-weight: 700; color: var(--text-main); padding: 8px 0;">Penanggung Jawab / Owner</td>
                    <td style="color: var(--text-muted); padding: 8px 0;">: Ilham Pradani</td>
                </tr>
            </table>
        </div>
        
        <p style="font-size: 0.95rem; color: var(--text-muted);">Sebagai perusahaan yang legal dan patuh pajak, kami berkomitmen untuk menyediakan lingkungan transaksi digital yang 100% aman dan berlandaskan hukum yang berlaku di Negara Kesatuan Republik Indonesia.</p>
    </div>
</PenggabungPageIncludeFooter>
