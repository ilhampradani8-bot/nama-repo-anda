---
// reseller_koneksi.astro
import ResellerNavbar from '../components/reseller/ResellerNavbar.astro';
import ResellerProfileCard from '../components/reseller/ResellerProfileCard.astro';
import ResellerSidebar from '../components/reseller/ResellerSidebar.astro';
import BottomNav from '../components/BottomNav.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Koneksi API Reseller | EasyMall Partner</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #1a202c;
            --primary: #4f46e5;
            --primary-hover: #4338ca;
            --border-color: #e2e8f0;
            --card-bg: #ffffff;
            --code-bg: #1e1e24;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.6;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            margin: 1.5rem auto;
            padding: 0 1.5rem;
            flex-grow: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 2rem;
        }

        .sidebar-col {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            overflow: hidden;
        }

        .card-header {
            background: #ffffff;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border-color);
            font-weight: 700;
            font-size: 1.15rem;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-body {
            padding: 1.75rem;
            display: flex;
            flex-direction: column;
            gap: 1.75rem;
        }

        .section-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 0.75rem;
            border-left: 4px solid var(--primary);
            padding-left: 10px;
        }

        .badge-method {
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        .badge-post {
            background-color: #e0e7ff;
            color: #4f46e5;
        }
        .badge-get {
            background-color: #dcfce7;
            color: #15803d;
        }

        .api-url-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'Fira Code', monospace;
            font-size: 0.85rem;
            color: #334155;
            margin-top: 0.5rem;
        }

        .btn-copy {
            background: var(--primary);
            color: #ffffff;
            border: none;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-copy:hover {
            background: var(--primary-hover);
        }

        pre {
            background: var(--code-bg);
            color: #f8fafc;
            padding: 16px;
            border-radius: 8px;
            font-family: 'Fira Code', monospace;
            font-size: 0.85rem;
            overflow-x: auto;
            line-height: 1.5;
            border: 1px solid #2d2d30;
        }

        .doc-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 0.5rem;
            font-size: 0.9rem;
        }

        .doc-table th, .doc-table td {
            border: 1px solid var(--border-color);
            padding: 10px 12px;
            text-align: left;
        }

        .doc-table th {
            background-color: #f8fafc;
            font-weight: 600;
            color: #475569;
        }

        .alert-info {
            background-color: #eff6ff;
            border: 1px solid #bfdbfe;
            border-radius: 8px;
            padding: 1rem;
            color: #1e3a8a;
            font-size: 0.9rem;
        }

        @media (max-width: 992px) {
            body {
                padding-bottom: 74px !important;
            }
            .container {
                grid-template-columns: 1fr;
            }
            .sidebar-col {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <ResellerNavbar />

    <div class="container">
        <div class="sidebar-col">
            <ResellerProfileCard />
            <ResellerSidebar activeTab="koneksi" />
        </div>

        <div class="content-area">
            <!-- HEADER INFO CARD -->
            <div class="card">
                <div class="card-header">🔌 Integrasi Developer & Reseller API</div>
                <div class="card-body">
                    <p style="color: #64748b; font-size: 0.95rem;">
                        Hubungkan sistem transaksi EasyMall ke dalam aplikasi, web, atau bot reseller Anda sendiri. 
                        Seluruh API kami dikemas secara <b>White-Label</b> untuk menjaga privasi bisnis Anda dengan klien.
                    </p>
                    <div class="alert-info">
                        <strong>💡 Katalog Layanan Digital Portal Pulsa & KoalaStore:</strong><br>
                        Kami mendukung transaksi otomatis Pulsa Reguler (Semua Operator), Paket Data, Token Listrik PLN, sertifikat SSL/Domain, 
                        hingga <b>Top-Up Game / Diamond (Mobile Legends, Free Fire, PUBG Mobile, Garena Shells)</b> yang semuanya diproses 24 jam secara real-time.
                    </div>
                </div>
            </div>

            <!-- API KEY CARD -->
            <div class="card">
                <div class="card-header">🔐 Kredensial Akses API</div>
                <div class="card-body">
                    <div>
                        <h4 style="margin-bottom: 0.25rem; font-size: 0.95rem;">Reseller API Key Anda:</h4>
                        <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 0.5rem;">Sertakan key ini di setiap request ke endpoint kami.</p>
                        <div class="api-url-box">
                            <span id="reseller-api-key" style="color: #10b981; font-weight: 700;">DEMO_RESELLER_KEY_X987HSD23</span>
                            <button class="btn-copy" onclick="copyText('reseller-api-key')">Salin Key</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- GET PRODUCTS ENDPOINT -->
            <div class="card">
                <div class="card-header">
                    <span class="badge-method badge-get">GET</span>
                    <span>1. Endpoint Daftar Produk (Pricelist)</span>
                </div>
                <div class="card-body">
                    <p style="color: #64748b; font-size: 0.9rem;">Mengambil daftar seluruh produk beserta kode produk (variant_code), harga, dan status ketersediaannya.</p>
                    
                    <div class="api-url-box">
                        <span id="endpoint-products">GET https://api.ilhampradani.me/api/products</span>
                        <button class="btn-copy" onclick="copyText('endpoint-products')">Salin URL</button>
                    </div>

                    <h4 class="section-title" style="margin-top: 1rem;">Query Parameters</h4>
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>Parameter</th>
                                <th>Tipe</th>
                                <th>Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>category_slug</code></td>
                                <td>String</td>
                                <td>Filter kategori: <code>pulsa</code>, <code>data</code>, <code>pln</code>, <code>game</code>, <code>music</code>, <code>productivity</code>, <code>ssl</code></td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 class="section-title" style="margin-top: 1rem;">Contoh Response Sukses</h4>
                    <pre><code>{`{
  "success": true,
  "products": [
    {
      "product_code": "TELKOMSEL_PROMO",
      "variant_code": "t5000",
      "name": "Telkomsel Rp 5.000",
      "price": 5750,
      "category": "pulsa",
      "status": "normal"
    },
    {
      "product_code": "MOBILE_LEGENDS",
      "variant_code": "ml_86",
      "name": "Mobile Legends 86 Diamonds",
      "price": 19600,
      "category": "game",
      "status": "normal"
    }
  ]
}`}</code></pre>
                </div>
            </div>

            <!-- CHECKOUT ENDPOINT -->
            <div class="card">
                <div class="card-header">
                    <span class="badge-method badge-post">POST</span>
                    <span>2. Endpoint Buat Transaksi (Checkout)</span>
                </div>
                <div class="card-body">
                    <p style="color: #64748b; font-size: 0.9rem;">Membuat transaksi baru untuk memicu pembayaran QRIS dan pengisian pulsa/game otomatis.</p>
                    
                    <div class="api-url-box">
                        <span id="endpoint-checkout">POST https://api.ilhampradani.me/api/checkout</span>
                        <button class="btn-copy" onclick="copyText('endpoint-checkout')">Salin URL</button>
                    </div>

                    <h4 class="section-title" style="margin-top: 1rem;">Request Payload (JSON)</h4>
                    <table class="doc-table">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Tipe</th>
                                <th>Wajib</th>
                                <th>Keterangan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><code>reseller_key</code></td>
                                <td>String</td>
                                <td>Ya</td>
                                <td>API Key Reseller Anda</td>
                            </tr>
                            <tr>
                                <td><code>whatsapp_id</code></td>
                                <td>String</td>
                                <td>Ya</td>
                                <td>No. WA pembeli untuk notifikasi status (e.g. <code>081234567890</code>)</td>
                            </tr>
                            <tr>
                                <td><code>product_code</code></td>
                                <td>String</td>
                                <td>Ya</td>
                                <td>Kode kategori produk (e.g. <code>TELKOMSEL_PROMO</code> / <code>MOBILE_LEGENDS</code>)</td>
                            </tr>
                            <tr>
                                <td><code>variant_code</code></td>
                                <td>String</td>
                                <td>Ya</td>
                                <td>Kode varian produk dari API pricelist (e.g. <code>t5000</code> / <code>ml_86</code>)</td>
                            </tr>
                            <tr>
                                <td><code>target</code></td>
                                <td>String</td>
                                <td>Ya</td>
                                <td>Nomor HP Tujuan / ID Game / Email Pelanggan</td>
                            </tr>
                            <tr>
                                <td><code>amount</code></td>
                                <td>Number</td>
                                <td>Ya</td>
                                <td>Harga produk (disesuaikan dengan API pricelist)</td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 class="section-title" style="margin-top: 1rem;">Contoh Request Payload (Top Up Diamond ML)</h4>
                    <pre><code>{`{
  "reseller_key": "DEMO_RESELLER_KEY_X987HSD23",
  "whatsapp_id": "081234567890",
  "product_code": "MOBILE_LEGENDS",
  "variant_code": "ml_86",
  "target": "12345678(1234)",
  "amount": 19600
}`}</code></pre>

                    <h4 class="section-title" style="margin-top: 1rem;">Contoh Response Sukses (QRIS Ditampilkan)</h4>
                    <pre><code>{`{
  "success": true,
  "transaction_id": "TRX-PP-992138",
  "qr_image_url": "https://api.qrserver.com/v1/create-qr-code/?size=300&data=...",
  "amount": 19800,
  "provider": "portalpulsa"
}`}</code></pre>
                </div>
            </div>

            <!-- STATUS CHECK ENDPOINT -->
            <div class="card">
                <div class="card-header">
                    <span class="badge-method badge-get">GET</span>
                    <span>3. Endpoint Cek Status Transaksi</span>
                </div>
                <div class="card-body">
                    <p style="color: #64748b; font-size: 0.9rem;">Mengecek status pembayaran QRIS dan status fulfillment pengisian produk oleh sistem.</p>
                    
                    <div class="api-url-box">
                        <span id="endpoint-status">GET https://api.ilhampradani.me/api/order/status/&#123;transaction_id&#125;</span>
                        <button class="btn-copy" onclick="copyText('endpoint-status')">Salin URL</button>
                    </div>

                    <h4 class="section-title" style="margin-top: 1rem;">Contoh Response Sukses (Fulfillment Selesai)</h4>
                    <pre><code>{`{
  "success": true,
  "status": "paid",
  "message": "Fulfillment sukses dikirim ke nomor tujuan",
  "sn": "SN-99823102381203",
  "amount": 19800
}`}</code></pre>
                </div>
            </div>

            <!-- CODE IMPLEMENTATION EXAMPLES -->
            <div class="card">
                <div class="card-header">💻 Contoh Implementasi Kode</div>
                <div class="card-body">
                    <h4 class="section-title">Request Transaksi via cURL</h4>
                    <pre><code>{`curl -X POST https://api.ilhampradani.me/api/checkout \\
  -H "Content-Type: application/json" \\
  -d '{
    "reseller_key": "DEMO_RESELLER_KEY_X987HSD23",
    "whatsapp_id": "081234567890",
    "product_code": "TELKOMSEL_PROMO",
    "variant_code": "t5000",
    "target": "081299002233",
    "amount": 5750
  }'`}</code></pre>

                    <h4 class="section-title" style="margin-top: 1.5rem;">Request Transaksi via Python</h4>
                    <pre><code>{`import requests

url = "https://api.ilhampradani.me/api/checkout"
payload = {
    "reseller_key": "DEMO_RESELLER_KEY_X987HSD23",
    "whatsapp_id": "081234567890",
    "product_code": "TELKOMSEL_PROMO",
    "variant_code": "t5000",
    "target": "081299002233",
    "amount": 5750
}
response = requests.post(url, json=payload)
print(response.json())`}</code></pre>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        async function fetchResellerData() {
            try {
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                document.getElementById('reseller-name').textContent = authData.name;
                document.getElementById('reseller-email').textContent = authData.email;
                document.getElementById('avatar-initial').textContent = authData.name.charAt(0).toUpperCase();

                // Fetch real reseller key from dashboard data
                const dataRes = await fetch(`${API_BASE_URL}/api/dashboard/data?scope=admin`, { credentials: 'include' });
                if (dataRes.ok) {
                    const data = await dataRes.json();
                    if (data.success && data.resellers && data.resellers.length > 0) {
                        // Display the first active reseller key from the database
                        const key = data.resellers[0].activation_code;
                        document.getElementById('reseller-api-key').textContent = key;
                    } else {
                        document.getElementById('reseller-api-key').textContent = 'ACT-1001';
                    }
                } else {
                    document.getElementById('reseller-api-key').textContent = 'ACT-1001';
                }
            } catch (err) {
                console.error(err);
                document.getElementById('reseller-api-key').textContent = 'ACT-1001';
            }
        }

        function copyText(id) {
            const text = document.getElementById(id).textContent;
            navigator.clipboard.writeText(text);
            alert("Berhasil menyalin ke clipboard!");
        }

        async function performLogout() {
            try {
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        }

        fetchResellerData();
    </script>
    <BottomNav />
</body>
</html>
