---
// dashboard_user.astro
import UserNavbar from '../components/dashboard/UserNavbar.astro';
import UserProfileCard from '../components/dashboard/UserProfileCard.astro';
import UserSidebar from '../components/dashboard/UserSidebar.astro';
import WelcomeCard from '../components/dashboard/WelcomeCard.astro';
import SearchCard from '../components/dashboard/SearchCard.astro';
import TransactionTable from '../components/dashboard/TransactionTable.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Pelanggan | EasyMarket</title>
    
    <!-- Favicon & App Icons -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #212529;
            --border-color: #dee2e6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.5;
        }

        /* Container Layout */
        .container {
            max-width: 1140px;
            width: 100%;
            margin: 1.5rem auto;
            padding: 0 1rem;
            flex-grow: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
        }

        .sidebar-col {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Classic Table Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
            color: #212529;
        }

        th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid var(--border-color);
        }

        tr:hover td {
            background-color: #f1f3f5;
        }

        code {
            font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
            font-size: 0.85rem;
            background-color: #e9ecef;
            padding: 2px 4px;
            border-radius: 3px;
            color: #212529;
        }

        .no-data {
            padding: 3rem;
            text-align: center;
            color: #6c757d;
            font-size: 0.95rem;
            background: #ffffff;
        }

        /* Responsive Layout */
        @media (max-width: 768px) {
            .container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar Component -->
    <UserNavbar />

    <!-- Main Container -->
    <div class="container">
        <!-- Sidebar profile & menu -->
        <div class="sidebar-col">
            <UserProfileCard />
            <UserSidebar activeTab="dashboard" />
        </div>

        <!-- Main Content Area -->
        <div class="content-area">
            <!-- Welcome Info -->
            <WelcomeCard />

            <!-- Search Transaction -->
            <SearchCard />

            <!-- Transactions Table -->
            <TransactionTable />
        </div>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        let transactionsData = [];
        let userEmail = '';

        function formatRupiah(num) {
            if (num === null || num === undefined) return "Rp 0";
            return "Rp " + parseInt(num, 10).toLocaleString('id-ID');
        }

        async function fetchUserData() {
            try {
                // Fetch profile
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                userEmail = authData.email;
                document.getElementById('user-name').textContent = authData.name;
                document.getElementById('user-email').textContent = authData.email;
                document.getElementById('avatar-initial').textContent = authData.name.charAt(0).toUpperCase();

                // Fetch dashboard data
                const dataRes = await fetch(`${API_BASE_URL}/api/dashboard/data`, { credentials: 'include' });
                if (dataRes.ok) {
                    const res = await dataRes.json();
                    if (res.success) {
                        transactionsData = res.transactions || [];
                        renderTransactions(transactionsData);
                    } else {
                        showNoData();
                    }
                } else {
                    showNoData();
                }
            } catch (err) {
                console.error(err);
                showNoData();
            }
        }

        function renderTransactions(list) {
            const container = document.getElementById('table-container');
            if (list.length === 0) {
                container.innerHTML = '<div class="no-data">Belum ada transaksi tercatat.</div>';
                return;
            }

            container.innerHTML = `
                <table>
                    <thead>
                        <tr>
                            <th>ID Transaksi</th>
                            <th>Produk</th>
                            <th>Varian</th>
                            <th>Total Bayar</th>
                            <th>Tanggal</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${list.map(t => `
                            <tr>
                                <td><code>${t.transaction_id}</code></td>
                                <td>${t.product_name || '-'}</td>
                                <td>${t.variant_name || '-'}</td>
                                <td><span style="color: #28a745; font-weight: bold;">${formatRupiah(t.amount)}</span></td>
                                <td>${t.created_at}</td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
        }

        function filterTransactions() {
            const wa = document.getElementById('searchWa').value.trim();
            if (!wa) {
                renderTransactions(transactionsData);
                return;
            }

            // Filter transactions matching the WhatsApp input number
            const filtered = transactionsData.filter(t => t.whatsapp_id && t.whatsapp_id.includes(wa));
            renderTransactions(filtered);
        }

        function showNoData() {
            document.getElementById('table-container').innerHTML = '<div class="no-data">Gagal memuat transaksi. Silakan masuk kembali.</div>';
        }

        async function performLogout() {
            try {
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        }

        fetchUserData();
    </script>
</body>
</html>

