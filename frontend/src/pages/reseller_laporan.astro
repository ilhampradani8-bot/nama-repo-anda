---
// reseller_laporan.astro
import ResellerNavbar from '../components/reseller/ResellerNavbar.astro';
import ResellerProfileCard from '../components/reseller/ResellerProfileCard.astro';
import ResellerSidebar from '../components/reseller/ResellerSidebar.astro';
import ResellerStatsGrid from '../components/reseller/ResellerStatsGrid.astro';
import BottomNav from '../components/BottomNav.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Laporan Penjualan | EasyMall Partner</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #212529;
            --border-color: #dee2e6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.5;
        }

        .container {
            max-width: 1140px;
            width: 100%;
            margin: 1.5rem auto;
            padding: 0 1rem;
            flex-grow: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
        }

        .sidebar-col {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .card {
            background: #ffffff;
            border: 2px solid #dee2e6;
            border-radius: 4px;
            overflow: hidden;
        }

        .card-header {
            background: #f8f9fa;
            padding: 0.75rem 1.25rem;
            border-bottom: 2px solid #dee2e6;
            font-weight: bold;
            font-size: 1rem;
            color: #212529;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-body {
            padding: 1.5rem;
        }

        .btn-print {
            padding: 6px 12px;
            background: #28a745;
            color: white;
            border: 1px solid #28a745;
            border-radius: 4px;
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .btn-print:hover {
            background: #218838;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
        }

        th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid var(--border-color);
        }

        .no-data {
            padding: 3rem;
            text-align: center;
            color: #6c757d;
        }

        @media (max-width: 768px) {
            body {
                padding-bottom: 74px !important;
            }
            .container {
                grid-template-columns: 1fr;
            }
            .sidebar-col {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <ResellerNavbar />

    <div class="container">
        <div class="sidebar-col">
            <ResellerProfileCard />
            <ResellerSidebar activeTab="laporan" />
        </div>

        <div class="content-area">
            <ResellerStatsGrid />

            <div class="card">
                <div class="card-header">
                    <span>📈 Laporan Rangkuman Penjualan</span>
                    <button class="btn-print" onclick="window.print()">🖨️ Cetak Laporan</button>
                </div>
                <div class="card-body">
                    <div id="table-container" style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr>
                                    <th>Metrik</th>
                                    <th>Nilai Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Total Transaksi Sukses</td>
                                    <td id="row-orders" style="font-weight: bold;">-</td>
                                </tr>
                                <tr>
                                    <td>Total Pendapatan Kotor (Omset)</td>
                                    <td id="row-sales" style="font-weight: bold; color: #007bff;">-</td>
                                </tr>
                                <tr>
                                    <td>Total Profit Reseller (Keuntungan Bersih)</td>
                                    <td id="row-profit" style="font-weight: bold; color: #28a745;">-</td>
                                </tr>
                                <tr>
                                    <td>Rata-rata Margin per Transaksi</td>
                                    <td id="row-avg-markup" style="font-weight: bold;">-</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        function formatRupiah(num) {
            if (num === null || num === undefined) return "Rp 0";
            return "Rp " + parseInt(num, 10).toLocaleString('id-ID');
        }

        async function fetchResellerData() {
            try {
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                document.getElementById('reseller-name').textContent = authData.name;
                document.getElementById('reseller-email').textContent = authData.email;
                document.getElementById('avatar-initial').textContent = authData.name.charAt(0).toUpperCase();

                const dataRes = await fetch(`${API_BASE_URL}/api/dashboard/data`, { credentials: 'include' });
                if (dataRes.ok) {
                    const data = await dataRes.json();
                    if (data.success) {
                        populateLaporan(data);
                    }
                }
            } catch (err) {
                console.error(err);
            }
        }

        function populateLaporan(data) {
            // Stats Grid
            document.getElementById('stat-orders').textContent = data.total_orders;
            document.getElementById('stat-sales').textContent = formatRupiah(data.total_sales);
            document.getElementById('stat-profit').textContent = formatRupiah(data.total_profit);

            // Table Rows
            document.getElementById('row-orders').textContent = data.total_orders + " Pesanan";
            document.getElementById('row-sales').textContent = formatRupiah(data.total_sales);
            document.getElementById('row-profit').textContent = formatRupiah(data.total_profit);
            
            const avg = data.total_orders > 0 ? Math.round(data.total_profit / data.total_orders) : 0;
            document.getElementById('row-avg-markup').textContent = formatRupiah(avg);
        }

        async function performLogout() {
            try {
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        }

        fetchResellerData();
    </script>
    <BottomNav />
</body>
</html>
