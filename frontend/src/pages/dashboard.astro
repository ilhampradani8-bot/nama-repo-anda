---
// dashboard.astro
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EasyMarket Dashboard Gateway</title>
    <!-- Favicon & App Icons -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #0b0f19;
            --card-bg: rgba(17, 24, 39, 0.7);
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --border-color: rgba(255, 255, 255, 0.08);
            --primary: #6366f1;
            --radius: 16px;
            --font-sans: 'Outfit', sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: var(--font-sans);
        }

        body {
            background-color: var(--bg-color);
            background-image: radial-gradient(circle at 50% 50%, rgba(99, 102, 241, 0.15) 0%, transparent 50%);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .gateway-card {
            width: 100%;
            max-width: 440px;
            background: var(--card-bg);
            backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            padding: 3rem 2rem;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(99, 102, 241, 0.1);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 1.5rem auto;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        p {
            font-size: 0.95rem;
            color: var(--text-muted);
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="gateway-card">
        <div class="spinner"></div>
        <h2>Mengamankan Sesi Anda...</h2>
        <p>Mengarahkan Anda ke halaman Dashboard yang sesuai secara otomatis.</p>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        async function checkSessionAndRoute() {
            try {
                const response = await fetch(`${API_BASE_URL}/api/auth/status`, {
                    credentials: 'include'
                });
                
                if (!response.ok) {
                    window.location.href = '/login.html';
                    return;
                }

                const data = await response.json();
                if (data.logged_in) {
                    const email = data.email || '';
                    const name = data.name || '';
                    
                    // Simple logic:
                    // If it is admin or demo account, we route to Reseller Dashboard as default,
                    // but let them switch easily, or we can check email.
                    // If email contains "reseller", "admin", "demo", let's route to Reseller Dashboard.
                    // Otherwise, route to User Dashboard.
                    if (email.includes('reseller') || name.includes('Reseller') || name.includes('Demo') || email.includes('admin') || name.includes('admin') || name.includes('Discord Demo')) {
                        window.location.href = '/dashboard_reseller.html';
                    } else {
                        window.location.href = '/dashboard_user.html';
                    }
                } else {
                    window.location.href = '/login.html';
                }
            } catch (err) {
                console.error(err);
                window.location.href = '/login.html';
            }
        }

        checkSessionAndRoute();
    </script>
</body>
</html>
