---
// login.astro
import PenggabungUtama from '../layouts/PenggabungUtama.astro';
---

<PenggabungUtama title="Masuk ke Akun Anda | EasyMall">
    <!-- Google Identity Services -->
    <script src="https://accounts.google.com/gsi/client" async defer is:inline></script>

    <style is:inline>
        :root {
            --login-bg: #f9fafb;
            --login-text-main: #1f2937;
            --login-text-muted: #4b5563;
            --login-border: #e5e7eb;
            --login-primary: #2563eb;
            --login-primary-hover: #1d4ed8;
        }

        .login-page-container {
            max-width: 1050px;
            margin: 4rem auto;
            padding: 0 1.5rem;
            min-height: calc(100vh - 500px);
            display: flex;
            align-items: center;
        }

        .login-wrapper-grid {
            display: grid;
            grid-template-columns: 1fr 1.1fr;
            gap: 4rem;
            width: 100%;
            align-items: center;
        }

        /* Left Side */
        .brand-side {
            display: flex;
            flex-direction: column;
            gap: 1.25rem;
        }

        .brand-logo-large {
            height: 64px;
            width: auto;
            align-self: flex-start;
        }

        .brand-side h1 {
            font-size: 2.2rem;
            font-weight: 800;
            color: var(--login-text-main);
            letter-spacing: -0.03em;
            line-height: 1.15;
        }

        .brand-side p {
            font-size: 1.1rem;
            color: var(--login-text-muted);
            line-height: 1.6;
        }

        .btn-back-store {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--login-text-muted);
            font-size: 0.95rem;
            font-weight: 600;
            transition: color 0.15s;
            margin-top: 0.5rem;
        }

        .btn-back-store:hover {
            color: var(--login-primary);
        }

        /* Right Side (Auth Card) */
        .auth-side-card {
            background: #ffffff;
            border: 1px solid var(--login-border);
            border-radius: 8px;
            padding: 2.5rem;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.04);
        }

        /* Auth Tabs Toggle */
        .auth-tabs {
            display: flex;
            border-bottom: 1px solid var(--login-border);
            margin-bottom: 1.5rem;
            gap: 1.5rem;
        }

        .auth-tab-btn {
            background: none;
            border: none;
            padding-bottom: 0.5rem;
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--login-text-muted);
            cursor: pointer;
            position: relative;
            transition: color 0.15s;
        }

        .auth-tab-btn:hover {
            color: var(--login-text-main);
        }

        .auth-tab-btn.active {
            color: var(--login-primary);
        }

        .auth-tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            width: 100%;
            height: 2px;
            background-color: var(--login-primary);
        }

        /* Form styling */
        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.35rem;
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--login-text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-control {
            width: 100%;
            padding: 11px 14px;
            background: #ffffff;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            font-size: 0.95rem;
            color: var(--login-text-main);
            outline: none;
            transition: all 0.15s;
        }

        .form-control:focus {
            border-color: var(--login-primary);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            background: none;
            border: none;
            color: var(--login-text-muted);
            cursor: pointer;
            font-size: 0.72rem;
            font-weight: 700;
            padding: 4px;
            transition: color 0.15s;
        }

        .toggle-password:hover {
            color: var(--login-primary);
        }

        .btn-submit {
            width: 100%;
            padding: 12px;
            background: var(--login-primary);
            color: #ffffff;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 700;
            margin-top: 0.25rem;
            transition: background-color 0.15s;
        }

        .btn-submit:hover {
            background-color: var(--login-primary-hover);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--login-text-muted);
            font-size: 0.7rem;
            font-weight: 700;
            margin: 1.5rem 0;
            letter-spacing: 0.08em;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid var(--login-border);
        }

        .divider:not(:empty)::before {
            margin-right: 0.75rem;
        }

        .divider:not(:empty)::after {
            margin-left: 0.75rem;
        }

        /* Social buttons */
        .social-buttons-grid {
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
        }

        .btn-social {
            width: 100%;
            padding: 10px;
            background: #ffffff;
            color: #374151;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.15s;
        }

        .btn-social:hover {
            background: #f9fafb;
            border-color: #c4c5c7;
        }

        .btn-demo {
            width: 100%;
            padding: 10px;
            background: #ecfdf5;
            color: #047857;
            border: 1.5px dashed #10b981;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 700;
            transition: all 0.15s;
        }

        .btn-demo:hover {
            background: #d1fae5;
            border-color: #059669;
        }

        .flash-message {
            background: #fef2f2;
            border: 1px solid #fca5a5;
            color: #b91c1c;
            padding: 10px 14px;
            border-radius: 6px;
            margin-bottom: 1.25rem;
            font-size: 0.88rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .register-info-box {
            background: #f9fafb;
            border: 1px solid var(--login-border);
            border-radius: 6px;
            padding: 1.5rem 1.25rem;
            font-size: 0.9rem;
            color: var(--login-text-muted);
            text-align: center;
        }

        .register-info-box h3 {
            color: var(--login-text-main);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        /* Responsive Layout */
        @media (max-width: 768px) {
            .login-page-container {
                margin: 2rem auto;
            }
            .login-wrapper-grid {
                grid-template-columns: 1fr;
                gap: 2.5rem;
            }
            .brand-side {
                text-align: center;
                align-items: center;
            }
            .brand-logo-large {
                align-self: center;
            }
            .brand-side h1 {
                font-size: 1.8rem;
            }
            .auth-side-card {
                padding: 1.75rem 1.5rem;
            }
        }
    </style>

    <div class="login-page-container">
        <div class="login-wrapper-grid">
            <!-- Left Side: Brand Logo and Title -->
            <div class="brand-side">
                <img src="/gambar/logo/easymall-logo.png" alt="EasyMall Logo" class="brand-logo-large">
                <h1>Selamat Datang di Portal EasyMall</h1>
                <p>Akses dasbor pelanggan Anda untuk melacak riwayat transaksi belanja, mengelola produk, dan meninjau tagihan Anda secara terpusat.</p>
                <div class="back-link-wrapper">
                    <a href="/" class="btn-back-store">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                        </svg>
                        Kembali ke Toko
                    </a>
                </div>
            </div>

            <!-- Right Side: Auth Card Form -->
            <div class="auth-side">
                <div class="auth-side-card">
                    <div class="auth-tabs">
                        <button type="button" class="auth-tab-btn active" id="tabLoginBtn" onclick="switchTab('login')">Masuk</button>
                        <button type="button" class="auth-tab-btn" id="tabRegisterBtn" onclick="switchTab('register')">Daftar</button>
                    </div>

                    <!-- Flash messages -->
                    <div id="flashMessage" class="flash-message" style="display: none;">
                        <span>⚠️</span> <span id="flashMessageText"></span>
                    </div>

                    <!-- Login Pane -->
                    <div id="loginPane">
                        <form id="loginForm" method="POST" autocomplete="off">
                            <div class="form-group">
                                <label for="username">Username</label>
                                <input type="text" id="username" name="username" class="form-control" placeholder="Masukkan username" required autofocus>
                            </div>

                            <div class="form-group">
                                <label for="password">Password</label>
                                <div class="input-wrapper">
                                    <input type="password" id="password" name="password" class="form-control" placeholder="Masukkan password" required>
                                    <button type="button" class="toggle-password" onclick="togglePasswordVisibility()">LIHAT</button>
                                </div>
                            </div>

                            <button type="submit" class="btn-submit">Masuk</button>
                            
                            <div class="divider">ATAU</div>

                            <div class="social-buttons-grid">
                                <!-- Google Auth Button Container -->
                                <div id="googleBtn" style="width: 100%; height: 44px; display: flex; justify-content: center; overflow: hidden; margin-bottom: 0.25rem;"></div>

                                <!-- Demo Button -->
                                <button type="button" class="btn-demo" onclick="loginAsDemo()">Masuk sebagai Demo (1-Click)</button>
                            </div>
                        </form>
                    </div>

                    <!-- Register Pane -->
                    <div id="registerPane" style="display: none;">
                        <div class="register-info-box">
                            <h3>Registrasi Ditutup</h3>
                            <p style="margin-bottom: 1rem;">Pendaftaran akun administrator secara manual dinonaktifkan untuk menjaga keamanan platform EasyMall.</p>
                            <p style="font-weight: 600; color: var(--login-primary); margin-bottom: 1.5rem;">Masuk dengan akun Google Anda untuk membuat profil secara instan!</p>
                            <button type="button" class="btn-submit" onclick="switchTab('login')">Kembali ke Login</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('password');
            const toggleBtn = document.querySelector('.toggle-password');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleBtn.textContent = 'SEMBUNYIKAN';
            } else {
                passwordInput.type = 'password';
                toggleBtn.textContent = 'LIHAT';
            }
        }

        function switchTab(tab) {
            const loginPane = document.getElementById('loginPane');
            const registerPane = document.getElementById('registerPane');
            const tabLoginBtn = document.getElementById('tabLoginBtn');
            const tabRegisterBtn = document.getElementById('tabRegisterBtn');

            if (tab === 'login') {
                loginPane.style.display = 'block';
                registerPane.style.display = 'none';
                tabLoginBtn.classList.add('active');
                tabRegisterBtn.classList.remove('active');
            } else {
                loginPane.style.display = 'none';
                registerPane.style.display = 'block';
                tabLoginBtn.classList.remove('active');
                tabRegisterBtn.classList.add('active');
            }
        }

        // Scoped login API URL — avoids conflict with global API_BASE_URL from index.js
        const LOGIN_API_URL = (window.location.protocol === 'file:' || window.location.port === '5002')
            ? 'http://localhost:5002'
            : 'https://api.ilhampradani.me';

        // Set action immediately to prevent empty action 404s on early clicks
        const loginForm = document.getElementById('loginForm');
        if (loginForm) {
            loginForm.action = LOGIN_API_URL + '/login';
        }

        // Render standard Google Button
        function renderGoogleButton() {
            if (typeof google !== 'undefined' && google.accounts) {
                const btnDiv = document.getElementById('googleBtn');
                if (btnDiv) {
                    google.accounts.id.renderButton(btnDiv, {
                        theme: "outline",
                        size: "large",
                        text: "signin_with",
                        shape: "rectangular",
                        width: btnDiv.offsetWidth || 340
                    });
                }
            }
        }

        // Use onGoogleLibraryLoad callback — guaranteed to fire after GSI fully loads
        // (more reliable than window.onload with async/defer scripts)
        window.onGoogleLibraryLoad = function() {
            google.accounts.id.initialize({
                client_id: "812430784237-70vet0sepo0f0eti0cs62nnjd4s89ia8.apps.googleusercontent.com",
                callback: handleCredentialResponse,
                use_fedcm_for_prompt: false  // Disable FedCM — avoids .well-known/web-identity requirement
            });
            renderGoogleButton();
        };

        // Fallback: also initialize on window.onload in case onGoogleLibraryLoad doesn't fire
        window.addEventListener('load', function() {
            if (typeof google !== 'undefined' && google.accounts) {
                google.accounts.id.initialize({
                    client_id: "812430784237-70vet0sepo0f0eti0cs62nnjd4s89ia8.apps.googleusercontent.com",
                    callback: handleCredentialResponse,
                    use_fedcm_for_prompt: false
                });
                renderGoogleButton();
            }
        });

        function handleCredentialResponse(response) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = LOGIN_API_URL + '/login/google';
            
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'credential';
            input.value = response.credential;
            
            form.appendChild(input);
            document.body.appendChild(form);
            form.submit();
        }

        function loginAsDemo() {
            document.getElementById('username').value = 'demo';
            document.getElementById('password').value = 'demo';
            document.getElementById('loginForm').submit();
        }
    </script>
</PenggabungUtama>
