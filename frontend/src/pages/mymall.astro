---
// mymall.astro
import UserNavbar from '../components/dashboard/UserNavbar.astro';
import BottomNav from '../components/BottomNav.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Mall | EasyMall</title>
    
    <!-- Google Fonts - Marcellus SC -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Marcellus+SC&display=swap" rel="stylesheet">
    
    <!-- Favicon & App Icons -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #212529;
            --border-color: #dee2e6;
            --primary-gradient: linear-gradient(135deg, #6610f2 0%, #0d6efd 100%);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding-bottom: 60px; /* For BottomNav */
        }

        .container {
            max-width: 1200px;
            margin: 20px auto;
            padding: 0 15px;
            width: 100%;
        }

        /* Profile Storefront Header Wrapper (Full Width) */
        .store-header-wrapper {
            width: 100%;
            background: linear-gradient(rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.94)), url('/gambar/luxury_hero.webp') no-repeat center center;
            background-size: cover;
            border-bottom: 1px solid var(--border-color);
            padding: 2.5rem 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            margin-bottom: 2rem;
        }

        .store-header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 15px;
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .store-profile-row {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .store-avatar-wrapper {
            position: relative;
            width: 90px;
            height: 90px;
            border-radius: 50%;
            padding: 0;
            border: 1px solid var(--border-color);
        }

        .store-avatar {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            background: #f8f9fa;
        }

        .store-info {
            flex: 1;
            min-width: 250px;
        }

        .store-name {
            font-size: 1.8rem;
            font-weight: 800;
            color: #212529;
            margin-bottom: 4px;
            letter-spacing: -0.5px;
            font-family: 'Marcellus SC', serif;
        }

        .store-tagline {
            font-size: 1rem;
            color: #6c757d;
            margin-bottom: 12px;
        }

        .store-badges {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .store-badge {
            background: #f1f3f5;
            border: 1px solid #dee2e6;
            color: #495057;
            padding: 4px 10px;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .store-badge.verified {
            background: #e8f5e9;
            border-color: #c8e6c9;
            color: #2e7d32;
        }

        /* Store Stats List */
        .store-stats-list {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
            border-top: 1px solid #f1f3f5;
            padding-top: 1.25rem;
            font-size: 0.95rem;
            color: #495057;
        }

        .stat-item {
            display: flex;
            align-items: center;
        }

        /* Products Listing Section */
        .section-title {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: #212529;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'Marcellus SC', serif;
        }

        /* Products Grid */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 1rem;
        }

        @media (max-width: 600px) {
            .product-grid {
                grid-template-columns: repeat(2, 1fr) !important;
                gap: 0.5rem !important;
            }
            .card-image-wrapper {
                height: 85px !important;
            }
            .card-body {
                padding: 0.75rem !important;
            }
            .card-title {
                font-size: 0.85rem !important;
                margin-bottom: 4px !important;
            }
            .card-desc {
                font-size: 0.75rem !important;
                margin-bottom: 8px !important;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }
        }

        .card {
            background: #ffffff;
            border: 1px solid var(--border-color);
            border-radius: 6px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.2s ease;
            position: relative;
        }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
            border-color: #bbbbbb;
        }

        .card-image-wrapper {
            background: #f8f9fa;
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            border-bottom: 1px solid var(--border-color);
            transition: background-color 0.2s ease;
        }

        .card:hover .card-image-wrapper {
            background-color: #f1f3f5;
        }

        .card-body {
            padding: 0.75rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .product-category {
            font-size: 0.68rem;
            text-transform: uppercase;
            color: #6c757d;
            font-weight: 700;
            margin-bottom: 4px;
            letter-spacing: 0.5px;
        }

        .card-title {
            font-size: 0.85rem;
            font-weight: 600;
            color: #212529;
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .card-desc {
            font-size: 0.75rem;
            color: #6c757d;
            margin-bottom: 12px;
            line-height: 1.4;
            flex-grow: 1;
        }

        .product-rating {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.72rem;
            margin-bottom: 12px;
        }

        .stars {
            color: #fadb14;
        }

        .sold-count {
            color: #6c757d;
            border-left: 1px solid var(--border-color);
            padding-left: 6px;
        }

        .product-footer {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-top: auto;
            border-top: 1px dashed var(--border-color);
            padding-top: 10px;
        }

        .price-container {
            display: flex;
            flex-direction: column;
        }

        .price-label {
            font-size: 0.65rem;
            color: #6c757d;
        }

        .price-value {
            font-size: 0.95rem;
            font-weight: 700;
            color: #e03131;
        }

        .product-item-badge {
            position: absolute;
            top: 8px;
            left: 8px;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            color: #ffffff;
            letter-spacing: 0.2px;
            z-index: 2;
        }

        .card-gallery {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 4px;
            margin-top: 5px;
        }

        .card-gallery img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            transition: border-color 0.15s;
            flex-shrink: 0;
        }

        .card-gallery img:hover {
            border-color: #0d6efd;
        }

        /* Toast notifications */
        .toast-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .toast {
            background: #ffffff;
            border-left: 4px solid #0d6efd;
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            padding: 12px 20px;
            border-radius: 4px;
            font-size: 0.9rem;
            font-weight: 600;
            min-width: 250px;
            animation: slideIn 0.3s ease-out;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .toast.toast-danger {
            border-left-color: #dc3545;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        /* Lightbox modal */
        .lightbox-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            z-index: 1050;
            display: none;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .lightbox-modal.active {
            display: flex;
            opacity: 1;
        }

        .lightbox-content {
            position: relative;
            max-width: 90%;
            max-height: 90%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .lightbox-content img {
            max-width: 100%;
            max-height: 80vh;
            border-radius: 8px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        }

        .lightbox-close {
            position: absolute;
            top: -40px;
            right: 0;
            color: #ffffff;
            font-size: 2rem;
            font-weight: bold;
            cursor: pointer;
            transition: color 0.15s;
        }

        .lightbox-close:hover {
            color: #bbb;
        }

        .no-data {
            text-align: center;
            padding: 3rem;
            color: #6c757d;
            background: #ffffff;
            border: 1px dashed var(--border-color);
            border-radius: 12px;
            grid-column: 1/-1;
        }

        /* Premium Settings and Application Forms */
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 16px;
            padding: 2.5rem;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
            margin: 2rem auto;
            max-width: 700px;
        }

        .apply-title {
            font-family: 'Marcellus SC', serif;
            font-size: 2rem;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-align: center;
            margin-bottom: 1rem;
            font-weight: 800;
        }

        .apply-subtitle {
            text-align: center;
            color: #6c757d;
            margin-bottom: 2rem;
            font-size: 1rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-size: 0.9rem;
            font-weight: 600;
            color: #495057;
            margin-bottom: 0.5rem;
        }

        .form-control {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            font-size: 0.95rem;
            background: #ffffff;
            color: #212529;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            border-color: #6f42c1;
            box-shadow: 0 0 0 3px rgba(111, 66, 193, 0.15);
            outline: none;
        }

        .social-input-group {
            position: relative;
            display: flex;
            align-items: center;
        }

        .social-icon-prefix {
            position: absolute;
            left: 12px;
            color: #6c757d;
            font-size: 1.1rem;
        }

        .social-input-group .form-control {
            padding-left: 2.5rem;
        }

        .switch-group {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            margin-bottom: 1.5rem;
        }

        .switch-label-desc {
            font-size: 0.8rem;
            color: #6c757d;
            margin-top: 2px;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 50px;
            height: 26px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #6f42c1;
        }

        input:checked + .slider:before {
            transform: translateX(24px);
        }

        .btn-primary-gradient {
            background: var(--primary-gradient);
            color: #ffffff;
            border: none;
            padding: 0.85rem 2rem;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            font-size: 1rem;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2);
            text-align: center;
        }

        .btn-primary-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(13, 110, 253, 0.3);
        }

        .settings-btn {
            background: #ffffff;
            border: 1px solid #dee2e6;
            color: #495057;
            padding: 8px 16px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
        }

        .settings-btn:hover {
            background: #f1f3f5;
            border-color: #ced4da;
            color: #212529;
        }

        .settings-panel {
            display: none;
            animation: fadeIn 0.3s ease;
            margin-bottom: 2rem;
        }

        .social-link-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #ffffff;
            border: 1px solid #dee2e6;
            color: #495057;
            transition: all 0.2s ease;
            text-decoration: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
            font-size: 1.1rem;
        }

        .social-link-icon:hover {
            transform: scale(1.1);
            color: #6f42c1;
            border-color: #6f42c1;
            box-shadow: 0 4px 12px rgba(111, 66, 193, 0.15);
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <UserNavbar />

    <!-- Application Form View (Shown when store doesn't exist) -->
    <div id="store-apply-view" style="display: none;" class="container">
        <div class="glass-card">
            <h1 class="apply-title">Pengajuan Buka Toko</h1>
            <p class="apply-subtitle">Mulai bangun reputasi lapak digital premium Anda di EasyMall</p>
            
            <form id="apply-store-form" onsubmit="submitApplyStore(event)">
                <div class="form-group">
                    <label for="apply-store-name">Nama Toko *</label>
                    <input type="text" id="apply-store-name" class="form-control" placeholder="Contoh: Easy Fast Cell" required>
                </div>
                
                <div class="form-group">
                    <label for="apply-store-category">Kategori Toko *</label>
                    <select id="apply-store-category" class="form-control" required>
                        <option value="digital">Digital & Lisensi</option>
                        <option value="jasa">Jasa & Freelancing</option>
                        <option value="layanan">Layanan Online / VPS</option>
                        <option value="voucher">Voucher & Top Up</option>
                        <option value="ebook">E-Book & Kursus</option>
                        <option value="lainnya">Lainnya</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="apply-store-desc">Deskripsi Toko *</label>
                    <textarea id="apply-store-desc" class="form-control" rows="3" placeholder="Jelaskan jenis produk atau layanan yang Anda sediakan..." required></textarea>
                </div>

                <div class="form-group">
                    <label for="apply-store-interests">Tag / Minat (Pisahkan dengan koma)</label>
                    <input type="text" id="apply-store-interests" class="form-control" placeholder="Contoh: pulsa, games, voucher, hosting">
                </div>

                <div class="form-group">
                    <label for="apply-store-phone">Nomor Kontak WhatsApp *</label>
                    <input type="text" id="apply-store-phone" class="form-control" placeholder="Contoh: 081234567890 atau 6281234567890" required>
                </div>

                <button type="submit" class="btn-primary-gradient">Kirim Pengajuan Pembukaan Toko</button>
            </form>
        </div>
    </div>

    <!-- Active Storefront View (Shown when store exists) -->
    <div id="storefront-active-view" style="display: none;">
        <!-- Store Header Wrapper (Full Width) -->
        <div class="store-header-wrapper">
            <div class="store-header-content">
                <div class="store-profile-row" style="justify-content: space-between; width: 100%;">
                    <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; flex: 1;">
                        <div class="store-avatar-wrapper">
                            <img id="store-avatar-img" src="/grabill54-hello-2488_512.gif" alt="Avatar Mall" class="store-avatar">
                        </div>
                        <div class="store-info">
                            <h1 class="store-name" id="store-title-name">My Mall</h1>
                            <div class="store-category-label" id="store-category-display" style="font-size: 0.95rem; font-weight: 700; color: #6f42c1; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; font-family: 'Marcellus SC', serif;">Lapak Digital Premium</div>
                            <div class="store-tagline" id="store-description-display" style="margin-bottom: 12px; font-size: 1rem; color: #6c757d;">Selamat datang di lapak digital premium saya. Temukan layanan terbaik di sini!</div>
                            <div class="store-badges">
                                <span class="store-badge verified" id="verified-badge" style="display: none;">
                                    🛡️ Merchant Terverifikasi
                                </span>
                                <span class="store-badge" id="pending-badge" style="display: none; background: #fff3cd; border-color: #ffe69c; color: #664d03;">
                                    ⌛ Menunggu Verifikasi
                                </span>
                                <span class="store-badge" id="hidden-badge" style="display: none; background: #f8d7da; border-color: #f5c2c7; color: #842029;">
                                    👁️ Hidden dari Publik
                                </span>
                                <span id="member-since-badge" style="display: none;"></span>
                                <span id="stat-active-variants" style="display: none;"></span>
                                <span id="stat-categories-count" style="display: none;"></span>
                            </div>
                            <div class="store-interests-row" id="store-interests-container" style="display:flex; gap:6px; flex-wrap:wrap; margin-top:10px;"></div>
                            
                            <!-- Socials Container -->
                            <div id="store-socials-container" style="display: flex; gap: 8px; margin-top: 15px;"></div>
                        </div>
                    </div>

                    <!-- Open settings button -->
                    <div style="margin-top: 10px; display: flex; align-self: flex-start;">
                        <button id="open-settings-btn" class="settings-btn" onclick="toggleSettingsPanel()">
                            ⚙️ Pengaturan Toko
                        </button>
                    </div>
                </div>

                <!-- Stats List Plain Section -->
                <div class="store-stats-list" style="display: flex; gap: 2rem; flex-wrap: wrap; border-top: 1px solid #f1f3f5; padding-top: 1.25rem; font-size: 0.95rem; color: #495057;">
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Produk:</span> <strong id="stat-total-products" style="color: #212529;">0</strong></div>
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Penilaian:</span> <strong style="color: #212529;">4.9 (482 Penilaian)</strong></div>
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Performa Chat:</span> <strong style="color: #212529;">99% (Hitungan Jam)</strong></div>
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Pengikut:</span> <strong style="color: #212529;">592,7RB</strong></div>
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Mengikuti:</span> <strong style="color: #212529;">0</strong></div>
                    <div class="stat-item"><span style="color: #868e96; margin-right: 4px;">Bergabung:</span> <strong style="color: #212529;">7 Tahun Lalu</strong></div>
                </div>
            </div>
        </div>

        <div class="container">
            <!-- Settings Panel Section -->
            <div id="settings-panel" class="settings-panel glass-card" style="margin-top: 0; margin-bottom: 2rem;">
                <h2 style="font-family: 'Marcellus SC', serif; margin-bottom: 1.5rem; color: #212529;">Pengaturan Toko</h2>
                
                <form id="settings-store-form" onsubmit="saveStoreSettings(event)">
                    <div class="form-group">
                        <label for="settings-store-name">Nama Toko</label>
                        <input type="text" id="settings-store-name" class="form-control" placeholder="Nama Toko Anda" required>
                    </div>

                    <div class="form-group">
                        <label for="settings-store-category">Kategori Toko</label>
                        <select id="settings-store-category" class="form-control" required>
                            <option value="digital">Digital & Lisensi</option>
                            <option value="jasa">Jasa & Freelancing</option>
                            <option value="layanan">Layanan Online / VPS</option>
                            <option value="voucher">Voucher & Top Up</option>
                            <option value="ebook">E-Book & Kursus</option>
                            <option value="lainnya">Lainnya</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="settings-store-desc">Deskripsi Toko</label>
                        <textarea id="settings-store-desc" class="form-control" rows="3" placeholder="Deskripsi toko..." required></textarea>
                    </div>

                    <div class="form-group">
                        <label for="settings-store-interests">Tag / Minat (Pisahkan dengan koma)</label>
                        <input type="text" id="settings-store-interests" class="form-control" placeholder="pulsa, games, voucher">
                    </div>

                    <div class="switch-group">
