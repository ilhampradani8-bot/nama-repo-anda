        function toggleSettingsPanel() {
            const panel = document.getElementById('settings-panel');
            if (panel.style.display === 'none' || !panel.style.display) {
                panel.style.display = 'block';
                // Populate fields
                document.getElementById('settings-store-name').value = storeDataObj.store_name || '';
                document.getElementById('settings-store-category').value = storeDataObj.store_category || 'digital';
                document.getElementById('settings-store-desc').value = storeDataObj.description || '';
                document.getElementById('settings-store-interests').value = storeDataObj.interests || '';
                document.getElementById('settings-store-visible').checked = storeDataObj.is_visible !== false && storeDataObj.is_visible !== 0;
                document.getElementById('settings-store-phone').value = storeDataObj.phone || '';
                document.getElementById('settings-store-instagram').value = storeDataObj.instagram || '';
                document.getElementById('settings-store-facebook').value = storeDataObj.facebook || '';
                document.getElementById('settings-store-tiktok').value = storeDataObj.tiktok || '';
                document.getElementById('settings-store-youtube').value = storeDataObj.youtube || '';
                
                panel.scrollIntoView({ behavior: 'smooth' });
            } else {
                panel.style.display = 'none';
            }
        }

        async function submitApplyStore(e) {
            e.preventDefault();
            const store_name = document.getElementById('apply-store-name').value.trim();
            const store_category = document.getElementById('apply-store-category').value;
            const description = document.getElementById('apply-store-desc').value.trim();
            const interests = document.getElementById('apply-store-interests').value.trim();
            const phone = document.getElementById('apply-store-phone').value.trim();

            try {
                const res = await fetch(`${API_BASE_URL}/api/user/store`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        store_name,
                        store_category,
                        description,
                        interests,
                        phone,
                        is_visible: true
                    }),
                    credentials: 'include'
                });

                if (res.ok) {
                    const data = await res.json();
                    if (data.success) {
                        showToast('Registrasi toko berhasil diajukan!', 'success');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        showToast(`Gagal mengajukan toko: ${data.error || ''}`, 'danger');
                    }
                } else {
                    showToast('Gagal mengajukan toko. Silakan coba lagi.', 'danger');
                }
            } catch (err) {
                console.error(err);
                showToast('Terjadi kesalahan jaringan.', 'danger');
            }
        }

        async function saveStoreSettings(e) {
            e.preventDefault();
            const store_name = document.getElementById('settings-store-name').value.trim();
            const store_category = document.getElementById('settings-store-category').value;
            const description = document.getElementById('settings-store-desc').value.trim();
            const interests = document.getElementById('settings-store-interests').value.trim();
            const is_visible = document.getElementById('settings-store-visible').checked;
            const phone = document.getElementById('settings-store-phone').value.trim();
            const instagram = document.getElementById('settings-store-instagram').value.trim();
            const facebook = document.getElementById('settings-store-facebook').value.trim();
            const tiktok = document.getElementById('settings-store-tiktok').value.trim();
            const youtube = document.getElementById('settings-store-youtube').value.trim();

            try {
                const res = await fetch(`${API_BASE_URL}/api/user/store`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        store_name,
                        store_category,
                        description,
                        interests,
                        is_visible,
                        phone,
                        instagram,
                        facebook,
                        tiktok,
                        youtube,
                        whatsapp: phone
                    }),
                    credentials: 'include'
                });

                if (res.ok) {
                    const data = await res.json();
                    if (data.success) {
                        showToast('Pengaturan toko berhasil disimpan!', 'success');
                        document.getElementById('settings-panel').style.display = 'none';
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        showToast(`Gagal menyimpan pengaturan: ${data.error || ''}`, 'danger');
                    }
                } else {
                    showToast('Gagal menyimpan pengaturan. Silakan coba lagi.', 'danger');
                }
            } catch (err) {
                console.error(err);
                showToast('Terjadi kesalahan jaringan.', 'danger');
            }
        }

        function renderSocialLinks(store) {
            const container = document.getElementById('store-socials-container');
            container.innerHTML = '';
            
            const socials = [
                { key: 'phone', label: 'WhatsApp', prefix: 'wa.me/', urlPrefix: 'https://wa.me/', icon: '💬' },
                { key: 'instagram', label: 'Instagram', prefix: 'instagram.com/', urlPrefix: '', icon: '📸' },
                { key: 'facebook', label: 'Facebook', prefix: 'facebook.com/', urlPrefix: '', icon: '👤' },
                { key: 'tiktok', label: 'TikTok', prefix: 'tiktok.com/', urlPrefix: '', icon: '🎵' },
                { key: 'youtube', label: 'YouTube', prefix: 'youtube.com/', urlPrefix: '', icon: '📺' }
            ];

            socials.forEach(s => {
                let val = store[s.key] || '';
                if (val) {
                    let href = val;
                    if (s.key === 'phone') {
                        let num = val.replace(/[^0-9]/g, '');
                        if (num.startsWith('0')) {
                            num = '62' + num.slice(1);
                        }
                        href = `${s.urlPrefix}${num}`;
                    } else if (!val.startsWith('http')) {
                        href = `https://${val}`;
                    }
                    
                    const el = document.createElement('a');
                    el.href = href;
                    el.target = '_blank';
                    el.className = 'social-link-icon';
                    el.title = s.label;
                    el.innerHTML = s.icon;
                    container.appendChild(el);
                }
            });
        }

        async function fetchStorefrontData() {
            try {
                // 1. Fetch authentication status to get user details
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                // Update Profile name fallback
                const nickname = authData.user ? (authData.user.username || 'Merchant') : 'Merchant';
                document.getElementById('store-title-name').textContent = `Mall milik ${nickname}`;
                
                // Formulate Join Date
                const createdAt = authData.user ? authData.user.created_at : '';
                if (createdAt) {
                    const formattedDate = new Date(createdAt).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' });
                    document.getElementById('member-since-badge').innerHTML = `📅 Bergabung: ${formattedDate}`;
                } else {
                    document.getElementById('member-since-badge').innerHTML = `📅 Bergabung: Baru-baru ini`;
                }

                // Fetch settings to get phone number
                try {
                    const settingsRes = await fetch(`${API_BASE_URL}/api/user/settings`, { credentials: 'include' });
                    if (settingsRes.ok) {
                        const settingsData = await settingsRes.json();
                        if (settingsData.success && settingsData.phone) {
                            merchantPhone = settingsData.phone;
                        }
                    }
                } catch (e) {
                    console.error("Error loading settings phone:", e);
                }

                // 1.1 Fetch user store details from database
                try {
                    const storeRes = await fetch(`${API_BASE_URL}/api/user/store`, { credentials: 'include' });
                    if (storeRes.ok) {
                        const storeData = await storeRes.json();
                        if (storeData.success && storeData.store_name) {
                            // Store exists! Show storefront active view, hide apply view
                            document.getElementById('storefront-active-view').style.display = 'block';
                            document.getElementById('store-apply-view').style.display = 'none';

                            storeDataObj = storeData;
                            
                            // Inject store details
                            document.getElementById('store-title-name').textContent = storeData.store_name;
                            document.getElementById('store-category-display').textContent = categoryMap[storeData.store_category] || storeData.store_category || 'Lapak Premium';
                            document.getElementById('store-description-display').textContent = storeData.description || 'Selamat datang di lapak digital premium saya.';
                            
                            // Inject verified / pending badge status
                            if (storeData.verified === 1) {
                                document.getElementById('verified-badge').style.display = 'inline-flex';
                                document.getElementById('pending-badge').style.display = 'none';
                            } else {
                                document.getElementById('verified-badge').style.display = 'none';
                                document.getElementById('pending-badge').style.display = 'inline-flex';
                            }

                            // Inject visibility badge
                            if (storeData.is_visible === 0 || storeData.is_visible === false) {
                                document.getElementById('hidden-badge').style.display = 'inline-flex';
                            } else {
                                document.getElementById('hidden-badge').style.display = 'none';
                            }

                            // Render socials
                            renderSocialLinks(storeData);
                            
                            if (storeData.phone) {
                                merchantPhone = storeData.phone;
                            }
                            
                            const interestsContainer = document.getElementById('store-interests-container');
                            interestsContainer.innerHTML = '';
                            if (storeData.interests) {
                                const list = storeData.interests.split(',').map(s => s.trim()).filter(Boolean);
                                list.forEach(interest => {
                                    const tag = document.createElement('span');
                                    tag.className = 'store-badge';
                                    tag.style.background = '#f3f0ff';
                                    tag.style.borderColor = '#d8b4fe';
                                    tag.style.color = '#6b21a8';
                                    tag.style.fontSize = '0.75rem';
                                    tag.style.fontWeight = 'bold';
                                    tag.style.padding = '3px 8px';
                                    tag.textContent = `# ${interest}`;
                                    interestsContainer.appendChild(tag);
                                });
                            }
                        } else {
                            // Store does not exist! Show apply view, hide active storefront view
                            document.getElementById('store-apply-view').style.display = 'block';
                            document.getElementById('storefront-active-view').style.display = 'none';
                        }
                    } else {
                        // Failed to fetch store, default to show apply view
                        document.getElementById('store-apply-view').style.display = 'block';
                        document.getElementById('storefront-active-view').style.display = 'none';
                    }
                } catch (storeErr) {
                    console.error("Error loading store details:", storeErr);
                    // Fallback to show apply view
                    document.getElementById('store-apply-view').style.display = 'block';
                    document.getElementById('storefront-active-view').style.display = 'none';
                }

                // 2. Fetch shared products of the user
                const res = await fetch(`${API_BASE_URL}/api/user/products`, { credentials: 'include' });
                if (res.ok) {
                    const data = await res.json();
                    if (data.success) {
                        allProductsList = data.products || [];
                        filterAndRenderProducts();
                    } else {
                        document.getElementById('mall-products-container').innerHTML = `<div class="no-data">Gagal memuat produk: ${data.error || ''}</div>`;
                    }
                } else {
                    document.getElementById('mall-products-container').innerHTML = '<div class="no-data">Gagal memuat produk mall Anda.</div>';
                }
            } catch (err) {
                console.error(err);
                document.getElementById('mall-products-container').innerHTML = '<div class="no-data">Terjadi kesalahan saat memuat mall.</div>';
            }
        }

        // Setup tab click listeners
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.onclick = () => {
                document.querySelectorAll('.tab-btn').forEach(b => {
                    b.classList.remove('active');
                    b.style.background = '#ffffff';
                    b.style.color = '#495057';
                    b.style.borderColor = '#ced4da';
                });
                btn.classList.add('active');
                btn.style.background = '#6f42c1';
                btn.style.color = '#ffffff';
                btn.style.borderColor = '#6f42c1';
                currentTabStatus = btn.dataset.status;
                filterAndRenderProducts();
            };
        });

        function filterAndRenderProducts() {
            let filtered = [];
            if (currentTabStatus === 'all') {
                filtered = allProductsList;
            } else if (currentTabStatus === 'publish') {
                filtered = allProductsList.filter(p => !['draft', 'review', 'blokir', 'dihapus'].includes(p.status));
            } else {
                filtered = allProductsList.filter(p => p.status === currentTabStatus);
            }
            renderMallProducts(filtered);
        }

        window.buyProduct = function(btn) {
            event.stopPropagation();
            const name = btn.getAttribute('data-name');
            const price = btn.getAttribute('data-price');
            if (!merchantPhone) {
                alert(`Silakan hubungi merchant untuk membeli "${name}".`);
                return;
            }
            let formattedPhone = merchantPhone.replace(/[^0-9]/g, '');
            if (formattedPhone.startsWith('0')) {
                formattedPhone = '62' + formattedPhone.slice(1);
            }
            const text = encodeURIComponent(`Halo, saya tertarik untuk membeli produk "${name}" seharga Rp${price} dari EasyMall Storefront Anda.`);
            window.open(`https://wa.me/${formattedPhone}?text=${text}`, '_blank');
        };

        function renderMallProducts(products) {
            const container = document.getElementById('mall-products-container');
            if (products.length === 0) {
                container.innerHTML = '<div class="no-data">Tidak ada produk untuk status ini.</div>';
                
                // Update stats
                document.getElementById('stat-total-products').textContent = allProductsList.length;
                document.getElementById('stat-active-variants').textContent = allProductsList.reduce((acc, p) => acc + (p.variants ? p.variants.length : 0), 0);
                document.getElementById('stat-categories-count').textContent = new Set(allProductsList.map(p => p.category)).size;
                return;
            }

            // Stats calculation from total list (always show global counts)
            let totalVariants = allProductsList.reduce((acc, p) => acc + (p.variants ? p.variants.length : 0), 0);
            const uniqueCategories = new Set(allProductsList.map(p => p.category));
            
            container.innerHTML = products.map(p => {
                const formattedPrice = new Intl.NumberFormat('id-ID', { minimumFractionDigits: 0 }).format(p.price);
                const categoryText = categoryMap[p.category] || categoryMap['lainnya'];

                // Status Badge (Remove publish status badge, keep draft, review, blokir, dihapus)
                let statusBadge = '';
                if (p.status === 'draft') {
                    statusBadge = `<span class="product-item-badge" style="background:#fff3cd; color:#664d03; border: 1px solid #ffe69c;">Draft</span>`;
                } else if (p.status === 'review') {
                    statusBadge = `<span class="product-item-badge" style="background:#cfe2ff; color:#084298; border: 1px solid #b6d4fe;">Review</span>`;
                } else if (p.status === 'blokir') {
                    statusBadge = `<span class="product-item-badge" style="background:#f8d7da; color:#842029; border: 1px solid #f5c2c7;">Blokir</span>`;
                } else if (p.status === 'dihapus') {
                    statusBadge = `<span class="product-item-badge" style="background:#e2e3e5; color:#41464b; border: 1px solid #d3d6d8;">Dihapus</span>`;
                }

                const mainImage = (p.images && p.images.length > 0) ? p.images[0] : '/gambar/logo/easymall-logo.png';

                return `
                    <div class="card product-card" onclick="window.location.href='/product_my.html?id=${p.id}'" style="cursor: pointer; display: flex; flex-direction: column; overflow: hidden;">
                        <div class="card-image-wrapper" style="height: 180px; position: relative; border-bottom: 1px solid var(--border-color); overflow: hidden;">
                            <img src="${mainImage}" alt="${p.product_name}" style="width: 100%; height: 100%; object-fit: cover;" onerror="this.src='/gambar/logo/easymall-logo.png'">
                            ${statusBadge}
                        </div>
                        <div class="card-body" style="padding: 0.75rem; display: flex; flex-direction: column; gap: 4px; flex-grow: 1;">
                            <h3 class="card-title" style="font-size: 0.9rem; font-weight: 700; color: #212529; margin: 0; line-height: 1.3;">${p.product_name}</h3>
                            <span class="product-category" style="font-size: 0.65rem; color: #6c757d; font-weight: 600; display: flex; align-items: center; gap: 2px;">
                                ${getCategorySvg(p.category)} ${categoryText}
                            </span>
                            <p class="card-desc" style="font-size: 0.75rem; color: #6c757d; margin: 4px 0 8px 0; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.8em;">
                                ${p.description || 'Tidak ada deskripsi.'}
                            </p>
                            
                            <div class="product-rating" style="display: flex; align-items: center; gap: 6px; font-size: 0.7rem; margin-bottom: 8px;">
                                <span class="stars" style="color: #ff9f43; display: flex; align-items: center; gap: 2px;">⭐ 4.9</span>
                                <span class="sold-count" style="color: #6c757d; border-left: 1px solid var(--border-color); padding-left: 6px;">100+ terjual</span>
                            </div>

                            <div class="product-footer" style="display: flex; align-items: flex-end; justify-content: space-between; margin-top: auto; border-top: 1px dashed var(--border-color); padding-top: 8px;">
                                <div class="price-container">
                                    <span class="price-label" style="font-size: 0.65rem; color: #6c757d;">Mulai dari</span>
                                    <div class="price-row" style="display: flex; align-items: center; flex-wrap: wrap; gap: 2px;">
                                        <span class="price-value" style="font-size: 0.95rem; color: #e03131; font-weight: 700;">Rp${formattedPrice}</span>
                                    </div>
                                </div>
                                <div style="display: flex; gap: 4px; align-items: center;">
                                    <button type="button" class="btn btn-buy" onclick="event.stopPropagation(); buyProduct(this)" data-name="${p.product_name.replace(/"/g, '&quot;')}" data-price="${p.price}" style="font-size: 0.75rem; padding: 0.3rem 0.6rem; border-radius: 4px; background: #6f42c1; border: 1px solid #6f42c1; color: white; cursor: pointer;">Beli</button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            // Set statistics
            document.getElementById('stat-total-products').textContent = allProductsList.length;
            document.getElementById('stat-active-variants').textContent = totalVariants;
            document.getElementById('stat-categories-count').textContent = uniqueCategories.size;
        }

        function openLightbox(url) {
            const lightbox = document.getElementById('lightbox-modal');
            const img = document.getElementById('lightbox-img');
            img.src = url;
            lightbox.classList.add('active');
        }

        function closeLightbox() {
            document.getElementById('lightbox-modal').classList.remove('active');
        }

        // Initialize Storefront
        fetchStorefrontData();
    </script>
    <BottomNav />
</body>
</html>
