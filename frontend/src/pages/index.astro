                        <!-- Kategori 1 -->
                        <a href="/hasil_pencarian.html?query=Perangkat Lunak & Aplikasi" class="category-card-link" style="text-decoration: none; color: inherit; scroll-snap-align: start;">
                            <div class="category-card" style="border: 1px solid var(--border-color); padding: 0.75rem 1.25rem; border-radius: var(--radius); background: #fafafa; transition: all 0.25s ease; display: flex; align-items: center; gap: 0.75rem; min-width: 290px; height: 56px;">
                                <div class="category-icon-wrapper" style="width: 36px; height: 36px; border-radius: 50%; background: #e0f2fe; color: #0284c7; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.25s;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><line x1="12" x2="12.01" y1="18" y2="18"/></svg>
                                </div>
                                <span style="font-size: 0.9rem; font-weight: 700; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Perangkat Lunak & Aplikasi</span>
                            </div>
                        </a>
                        
                        <!-- Kategori 2 -->
                        <a href="/hasil_pencarian.html?query=Jasa Desain & Kreatif" class="category-card-link" style="text-decoration: none; color: inherit; scroll-snap-align: start;">
