---
// reseller_penjualan.astro
import ResellerNavbar from '../components/reseller/ResellerNavbar.astro';
import ResellerProfileCard from '../components/reseller/ResellerProfileCard.astro';
import ResellerSidebar from '../components/reseller/ResellerSidebar.astro';
import BottomNav from '../components/BottomNav.astro';
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Penjualan Reseller | EasyMall Partner</title>
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <style>
        :root {
            --bg-color: #f8f9fa;
            --text-color: #212529;
            --border-color: #dee2e6;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.5;
        }

        .container {
            max-width: 1140px;
            width: 100%;
            margin: 1.5rem auto;
            padding: 0 1rem;
            flex-grow: 1;
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
        }

        .sidebar-col {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .content-area {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .card {
            background: #ffffff;
            border: 2px solid #dee2e6;
            border-radius: 4px;
            overflow: hidden;
        }

        .card-header {
            background: #f8f9fa;
            padding: 0.75rem 1.25rem;
            border-bottom: 2px solid #dee2e6;
            font-weight: bold;
            font-size: 1rem;
            color: #212529;
        }

        .card-body {
            padding: 1.25rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background-color: #ffffff;
        }

        th, td {
            padding: 12px 15px;
            text-align: left;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.9rem;
        }

        th {
            background-color: #f8f9fa;
            font-weight: 600;
            color: #495057;
            border-bottom: 2px solid var(--border-color);
        }

        tr:hover td {
            background-color: #f1f3f5;
        }

        code {
            font-family: monospace;
            font-size: 0.85rem;
            background-color: #e9ecef;
            padding: 2px 4px;
            border-radius: 3px;
            color: #212529;
        }

        .badge-active {
            background-color: #d1e7dd;
            color: #0f5132;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .badge-inactive {
            background-color: #f8d7da;
            color: #842029;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: bold;
        }

        .no-data {
            padding: 3rem;
            text-align: center;
            color: #6c757d;
        }

        .loading-spinner {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem 1rem;
            color: #007bff;
            gap: 10px;
            font-size: 0.9rem;
        }

        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid rgba(0, 123, 255, 0.1);
            border-top-color: #007bff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @media (max-width: 768px) {
            body {
                padding-bottom: 74px !important;
            }
            .container {
                grid-template-columns: 1fr;
            }
            .sidebar-col {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <ResellerNavbar />

    <div class="container">
        <div class="sidebar-col">
            <ResellerProfileCard />
            <ResellerSidebar activeTab="penjualan" />
        </div>

        <div class="content-area">
            <div class="card">
                <div class="card-header">👥 Daftar Klien & Penjualan Partner</div>
                <div class="card-body">
                    <div id="table-container" style="overflow-x: auto;">
                        <div class="loading-spinner">
                            <div class="spinner"></div>
                            Memuat data partner...
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        let API_BASE_URL = '';
        if (window.location.port !== '5002' && window.location.protocol !== 'file:') {
            API_BASE_URL = 'https://api.ilhampradani.me';
        }

        function formatRupiah(num) {
            if (num === null || num === undefined) return "Rp 0";
            return "Rp " + parseInt(num, 10).toLocaleString('id-ID');
        }

        async function fetchResellerData() {
            try {
                const authRes = await fetch(`${API_BASE_URL}/api/auth/status`, { credentials: 'include' });
                if (!authRes.ok) {
                    window.location.href = '/login.html';
                    return;
                }
                const authData = await authRes.json();
                if (!authData.logged_in) {
                    window.location.href = '/login.html';
                    return;
                }

                document.getElementById('reseller-name').textContent = authData.name;
                document.getElementById('reseller-email').textContent = authData.email;
                document.getElementById('avatar-initial').textContent = authData.name.charAt(0).toUpperCase();

                const dataRes = await fetch(`${API_BASE_URL}/api/dashboard/data?scope=admin`, { credentials: 'include' });
                if (dataRes.ok) {
                    const data = await dataRes.json();
                    if (data.success) {
                        renderResellers(data.resellers || []);
                    } else {
                        showNoData();
                    }
                } else {
                    showNoData();
                }
            } catch (err) {
                console.error(err);
                showNoData();
            }
        }

        function renderResellers(list) {
            const container = document.getElementById('table-container');
            if (list.length === 0) {
                container.innerHTML = '<div class="no-data">Belum ada reseller partner terdaftar.</div>';
                return;
            }

            container.innerHTML = `
                <table>
                    <thead>
                        <tr>
                            <th>Kode Aktivasi</th>
                            <th>WhatsApp ID</th>
                            <th>Nama Toko</th>
                            <th>Markup Margin</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${list.map(r => `
                            <tr>
                                <td><code>${r.activation_code || '-'}</code></td>
                                <td>${r.whatsapp_id || '-'}</td>
                                <td>${r.store_name || '-'}</td>
                                <td><span style="color: #28a745; font-weight: bold;">${formatRupiah(r.markup)}</span></td>
                                <td>
                                    ${r.is_active === 1 
                                        ? '<span class="badge-active">Aktif</span>' 
                                        : '<span class="badge-inactive">Non-Aktif</span>'}
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table>
            `;
        }

        function showNoData() {
            document.getElementById('table-container').innerHTML = '<div class="no-data">Gagal memuat data partner.</div>';
        }

        async function performLogout() {
            try {
                await fetch(`${API_BASE_URL}/logout`, { credentials: 'include' });
            } catch(e){}
            window.location.href = '/login.html';
        }

        fetchResellerData();
    </script>
    <BottomNav />
</body>
</html>
