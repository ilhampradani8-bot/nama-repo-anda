---
// service.astro
import PenggabungPageIncludeFooter from '../layouts/penggabung_pageincludefooter.astro';
---

<PenggabungPageIncludeFooter 
    title="Layanan Kami - EasyMall" 
    description="Jelajahi berbagai layanan unggulan EasyMall mulai dari distribusi produk digital, sertifikat SSL, otomatisasi WhatsApp/Telegram, hingga custom web development."
    activePage="service"
>
    <div class="footer-page-content" style="line-height: 1.8;">
        <h2 style="font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem; color: var(--text-main); border-bottom: 2px solid var(--primary); padding-bottom: 0.5rem;">Layanan Kami</h2>
        <p style="font-size: 1.05rem; margin-bottom: 1.5rem; color: var(--text-muted);">EasyMall menyediakan berbagai macam layanan digital berkualitas tinggi untuk individu, reseller, maupun korporat:</p>
        
        <div style="display: grid; gap: 1.5rem; margin-top: 1.5rem;">
            <div style="border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius); background: #fafafa;">
                <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #4f46e5;">1. Distribusi Produk Digital</h3>
                <p style="margin-bottom: 0; color: var(--text-muted);">Pengisian Pulsa, Paket Data, Token PLN, dan Voucher Game murah dari berbagai provider ternama yang diproses secara instan 24 jam dengan sistem otomatisasi API.</p>
            </div>

            <div style="border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius); background: #fafafa;">
                <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #4f46e5;">2. Sertifikat Keamanan SSL</h3>
                <p style="margin-bottom: 0; color: var(--text-muted);">Penerbitan sertifikat SSL (Sectigo, Let's Encrypt, dll.) dengan harga bersahabat dan verifikasi domain instan untuk mengamankan situs web bisnis Anda.</p>
            </div>

            <div style="border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius); background: #fafafa;">
                <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #4f46e5;">3. Otomatisasi WhatsApp & Telegram</h3>
                <p style="margin-bottom: 0; color: var(--text-muted);">Jasa pembuatan bot WhatsApp & Telegram otomatis terintegrasi kecerdasan buatan (AI) untuk kebutuhan Customer Service, Broadcast Notifikasi, dan integrasi sistem backend.</p>
            </div>

            <div style="border: 1px solid var(--border-color); padding: 1.5rem; border-radius: var(--radius); background: #fafafa;">
                <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 0.5rem; color: #4f46e5;">4. Konsultasi IT & Custom Software</h3>
                <p style="margin-bottom: 0; color: var(--text-muted);">Jasa pembuatan sistem web custom (E-Commerce, ERP, landing page, dll.) yang disesuaikan dengan kebutuhan bisnis Anda agar performa operasional meningkat.</p>
            </div>
        </div>
    </div>
</PenggabungPageIncludeFooter>
