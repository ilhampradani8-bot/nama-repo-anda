---
// PageUtama.astro - Shared HTML layout for EasyMarket
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BottomNav from '../components/BottomNav.astro';
import FloatingChat from '../components/FloatingChat.astro';

interface Props {
	title: string;
	description?: string;
	jsFile?: string;
}

const { 
	title = "EasyMarket | Top Up Game, Pulsa, & Layanan IT Instan Terlengkap", 
	description = "EasyMarket adalah platform top up game murah, pulsa, paket data instan, SSL certificate, serta layanan IT & Bot WhatsApp automation profesional.",
	jsFile = "/ecom/js/index.js"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="index, follow">
    <meta name="author" content="PT Easymall Software Development">
    
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="keywords" content="top up game, pulsa murah, paket data, voucher game, bot whatsapp, bot telegram, web development, ssl certificate, easymarket, produk digital">
    <link rel="canonical" href="http://139.59.122.230/">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="http://139.59.122.230/">
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content="/gambar/banner.webp">
    <meta property="og:site_name" content="EasyMarket">
    <meta property="og:locale" content="id_ID">

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="http://139.59.122.230/">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content="/gambar/banner.webp">

    <!-- Favicon & App Icons -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#4f46e5">

    <!-- Main CSS -->
    <link rel="stylesheet" href="/ecom/css/style.css">
    
    <style is:global>
        /* Drawer Styling */
        .pay-drawer {
            position: fixed;
            top: 0;
            right: 0;
            width: 100%;
            height: 100%;
            z-index: 2000;
            visibility: hidden;
            transition: visibility 0.3s;
        }

        .pay-drawer.active {
            visibility: visible;
        }

        .drawer-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .pay-drawer.active .drawer-overlay {
            opacity: 1;
        }

        .drawer-content {
            position: absolute;
            top: 0;
            right: -480px; /* Initially hidden */
            width: 100%;
            max-width: 480px;
            height: 100%;
            background: #ffffff;
            box-shadow: -5px 0 25px rgba(0, 0, 0, 0.15);
            padding: 2.5rem 2rem;
            overflow-y: auto;
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .pay-drawer.active .drawer-content {
            right: 0; /* Slide in */
        }

        .drawer-close-btn {
            position: absolute;
            top: 1rem;
            right: 1.2rem;
            background: transparent;
            border: none;
            font-size: 2rem;
            cursor: pointer;
            color: var(--text-muted);
            line-height: 1;
        }

        .drawer-close-btn:hover {
            color: var(--text-main);
        }

        /* Product View Styling */
        .product-main-layout {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            background: #ffffff;
            margin-bottom: 2rem;
            margin-top: 1rem;
        }

        .product-image-sec {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1.5rem;
            width: 100%;
        }

        .product-large-img {
            max-width: 100%;
            height: auto;
            max-height: 200px;
            object-fit: contain;
            margin-bottom: 1rem;
        }

        .product-large-icon {
            font-size: 5rem;
            margin-bottom: 1rem;
        }

        .product-details-sec {
            display: flex;
            flex-direction: column;
        }

        .product-cat-badge {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--primary);
            font-weight: 700;
            margin-bottom: 0.4rem;
        }

        .product-title-text {
            font-size: 1.6rem;
            font-weight: 800;
            line-height: 1.2;
            color: var(--text-main);
            margin-bottom: 0.6rem;
        }

        .product-meta-row {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-bottom: 1.2rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1rem;
        }

        .product-price-box {
            background: #fcfcfc;
            border: 1px solid var(--border-color);
            padding: 1.5rem;
            border-radius: var(--radius);
            margin-bottom: 2rem;
        }

        .product-price-box .price-label {
            font-size: 0.8rem;
            color: var(--text-muted);
            display: block;
            margin-bottom: 0.25rem;
        }

        .product-price-box .price-value {
            font-size: 2rem;
            font-weight: 800;
            color: #e03131;
        }

        .product-price-box .price-strike {
            text-decoration: line-through;
            color: var(--text-muted);
            font-size: 1rem;
            margin-left: 0.5rem;
        }

        .product-desc-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--text-main);
        }

        .product-desc-content {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        .btn-buy-now {
            padding: 14px 28px;
            background: var(--primary);
            color: #ffffff;
            border: 1px solid var(--primary);
            border-radius: var(--radius);
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            transition: opacity 0.15s;
            width: fit-content;
        }

        .btn-buy-now:hover {
            opacity: 0.9;
        }

        .btn-confirm:hover {
            opacity: 0.9;
        }

        .btn-confirm:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .btn-check-status:hover {
            background: var(--primary);
            color: #ffffff;
        }

        /* Footer styling details */
        .site-footer {
            background-color: #fafafa;
            border-top: 1px solid var(--border-color);
            padding: 4rem 0 2rem 0;
            margin-top: 4rem;
            color: var(--text-main);
            font-size: 0.9rem;
        }
        
        .footer-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
            display: grid;
            grid-template-columns: 1.5fr 1fr 1.2fr 1.5fr;
            gap: 2.5rem;
        }
        
        .footer-col h4 {
            font-size: 0.9rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .footer-logo {
            height: 150px;
            margin-bottom: 1.2rem;
            display: block;
        }
        
        .footer-description {
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .legal-info strong {
            display: block;
            margin-top: 1rem;
            font-weight: 600;
            color: var(--text-main);
        }
        
        .legal-info p {
            color: var(--text-muted);
            margin-bottom: 0.2rem;
            font-size: 0.85rem;
        }
        
        .footer-links ul {
            list-style: none;
            padding: 0;
        }
        
        .footer-links li {
            margin-bottom: 0.8rem;
        }
        
        .footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.15s;
        }
        
        .footer-links a:hover {
            color: var(--primary);
            text-decoration: underline;
        }
        
        .contact-details p {
            margin-bottom: 0.8rem;
            color: var(--text-muted);
        }
        
        .contact-details a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }
        
        .contact-details a:hover {
            text-decoration: underline;
        }
        
        .footer-search {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.8rem;
        }
        
        .footer-search-input {
            flex: 1;
            padding: 8px 12px;
            border: 1px solid var(--border-color);
            border-radius: var(--radius);
            outline: none;
            font-size: 0.85rem;
        }
        
        .footer-search-input:focus {
            border-color: var(--primary);
        }
        
        .footer-search-btn {
            padding: 8px 16px;
            background: var(--primary);
            color: #ffffff;
            border: 1px solid var(--primary);
            border-radius: var(--radius);
            cursor: pointer;
            font-weight: 600;
            font-size: 0.85rem;
        }
        
        .footer-bottom {
            max-width: 1400px;
            margin: 3rem auto 0 auto;
            padding: 1.5rem 2rem 0 2rem;
            border-top: 1px solid var(--border-color);
            text-align: center;
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        @media (max-width: 900px) {
            .product-main-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
                padding: 2rem;
            }
            .product-image-sec {
                border-right: none;
                padding-right: 0;
                border-bottom: 1px solid var(--border-color);
                padding-bottom: 2rem;
            }
            .recom-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .footer-container {
                grid-template-columns: 1fr;
                gap: 2rem;
            }
            .site-footer {
                padding: 3rem 0 1.5rem 0;
            }
        }

        @media (max-width: 600px) {
            .recom-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Mobile Bottom Nav Global Responsiveness */
        @media (max-width: 768px) {
            body {
                padding-bottom: 74px !important;
            }
            .main-header .main-nav {
                display: none !important;
            }
            .main-header .header-actions #loginBtn {
                display: none !important;
            }
            .main-header .header-actions .btn-cart {
                display: none !important;
            }
            .header-container {
                flex-direction: row !important;
                justify-content: space-between !important;
                gap: 0.5rem !important;
            }
            .main-header {
                padding: 0.4rem 0 !important;
                margin-bottom: 1rem !important;
            }
            .logo-img {
                height: 38px !important;
            }
            .search-input {
                width: 90px !important;
            }
            .search-input:focus {
                width: 120px !important;
            }
        }
    </style>
</head>
<body>
    <!-- Client Safe Header -->
    <Header />

    <slot />

    <!-- Client Safe Footer -->
    <Footer />

    <!-- Mobile Bottom Navigation Bar -->
    <BottomNav />

    <!-- Floating Chat Capsule Widget -->
    <FloatingChat />

    <!-- Scripts -->
    <script is:inline src={jsFile}></script>
</body>
</html>
